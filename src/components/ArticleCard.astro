---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  date: string; // ISO yyyy-mm-dd
  firm: 'HLB Ireland' | 'FutureRange';
  url: string;
  /** internal links open in place (→); external open on the firm's site (↗) */
  internal?: boolean;
  /** basename of a webp in assets/article-thumbs or assets/uploads */
  image?: string | null;
}
const { title, description, date, firm, url, internal = false, image } = Astro.props;

// Resolve the thumbnail by basename across both image folders.
const pool = import.meta.glob<{ default: ImageMetadata }>(
  ['../assets/article-thumbs/*.webp', '../assets/uploads/*.webp'],
  { eager: true }
);
let img: ImageMetadata | undefined;
if (image) {
  for (const [p, mod] of Object.entries(pool)) {
    const base = p.split('/').pop()!.replace(/\.[^.]+$/, '').toLowerCase();
    if (base === image.toLowerCase()) { img = mod.default; break; }
  }
}
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-IE', { day: 'numeric', month: 'short', year: 'numeric' });
const isFr = firm === 'FutureRange';
const ext = internal ? {} : { target: '_blank', rel: 'noopener noreferrer' };
---

<a class:list={['acard', { fr: isFr }]} href={url} {...ext}>
  <div class="acard-thumb">
    {img ? (
      <Image src={img} alt="" widths={[380, 640]} sizes="(min-width: 960px) 33vw, 85vw" loading="lazy" />
    ) : (
      <div class="acard-fallback" aria-hidden="true"><span>{isFr ? 'FutureRange' : 'HLB Ireland'}</span></div>
    )}
  </div>
  <div class="acard-body">
    <span class="acard-meta">
      <span class="acard-firm">{firm}</span>
      <time datetime={date}>{fmt(date)}</time>
    </span>
    <h3 class="acard-title">{title} <span class="acard-ic" aria-hidden="true">{internal ? '→' : '↗'}</span></h3>
    <p class="acard-desc">{description}</p>
  </div>
</a>

<style>
  .acard {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .acard.fr { border-top-color: var(--teal-bright); }
  @media (prefers-reduced-motion: no-preference) {
    .acard:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(0, 10, 14, 0.3); }
  }
  .acard:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .acard-thumb { position: relative; aspect-ratio: 16 / 10; background: var(--ink-deep); }
  .acard-thumb :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .acard-thumb::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26, 41, 48, 0.05), rgba(26, 41, 48, 0.35));
    pointer-events: none;
  }
  .acard-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background: radial-gradient(120% 120% at 30% 20%, var(--surface), var(--ink-deep));
  }
  .acard-fallback span {
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .acard.fr .acard-fallback span { color: var(--teal-ink); }

  .acard-body { padding: 18px 22px 24px; display: flex; flex-direction: column; flex: 1; }
  .acard-meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .acard-firm { font-weight: 800; color: var(--gold-deep); }
  .acard.fr .acard-firm { color: var(--teal-ink); }
  .acard-meta time { color: var(--body); }
  .acard-title { font-size: 1.08rem; line-height: 1.3; margin: 0; color: var(--head); }
  .acard-ic { color: var(--gold-deep); font-weight: 800; }
  .acard.fr .acard-ic { color: var(--teal-ink); }
  .acard-desc {
    margin: 10px 0 0;
    font-size: 0.88rem;
    color: var(--body);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
