---
import { href } from '../lib/paths';
interface Props {
  title?: string;
  body?: string;
  /** which blue to sit on, to keep the page's light/dark alternation going.
      'light' = lighter slate (default), 'dark' = darker blue. */
  tone?: 'light' | 'dark';
}
const {
  title = 'Let’s talk about what comes next',
  body = 'Whether you are growing, restructuring, navigating a technology change or planning for what comes next — the right conversation starts here.',
  tone = 'light',
} = Astro.props;
---

<section class="cta band on-dark" data-tone={tone}>
  <div class="container inner">
    <div data-reveal>
      <p class="eyebrow">Work with us</p>
      <h2>{title}</h2>
      <p class="body">{body}</p>
    </div>
    <div class="actions" data-reveal>
      <a class="btn btn-gold" href={href('/contact/')}>Get in touch <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<style>
  .cta { padding: 100px 0; position: relative; overflow: hidden; }
  .cta[data-tone='light'] { background: var(--band-bg); }
  .cta[data-tone='dark'] { background: var(--paper); }
  .cta::before {
    content: "";
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(600px 400px at 90% 10%, rgba(234, 182, 51, 0.14), transparent 60%),
      radial-gradient(640px 420px at 6% 90%, rgba(59, 191, 208, 0.16), transparent 62%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cta::before { animation: cta-aurora 17s ease-in-out infinite alternate; }
  }
  @keyframes cta-aurora {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(-3%, 3%, 0) scale(1.05); }
  }
  .cta .inner { position: relative; z-index: 1; }
  .inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
  }
  h2 {
    font-size: clamp(2rem, 3.8vw, 3rem);
    font-weight: 480;
    margin-bottom: 18px;
  }
  .body { color: var(--muted-on-dark); max-width: 48ch; }
  .actions { justify-self: end; }

  @media (max-width: 800px) {
    .inner { grid-template-columns: 1fr; }
    .actions { justify-self: start; }
  }
</style>
