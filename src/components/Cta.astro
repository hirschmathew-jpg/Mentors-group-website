---
interface Props {
  title?: string;
  body?: string;
}
const {
  title = 'Let’s talk about what comes next',
  body = 'Whether you are growing, restructuring, navigating a technology change or planning for what comes next — the right conversation starts here.',
} = Astro.props;
---

<section class="cta band on-dark">
  <div class="container inner">
    <div data-reveal>
      <p class="eyebrow">Work with us</p>
      <h2>{title}</h2>
      <p class="body">{body}</p>
    </div>
    <div class="actions" data-reveal>
      <a class="btn btn-gold" href="/contact/">Get in touch <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<style>
  .cta { padding: 100px 0; }
  .inner {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
  }
  h2 {
    font-size: clamp(2rem, 3.8vw, 3rem);
    font-weight: 480;
    margin-bottom: 18px;
  }
  .body { color: var(--muted-on-dark); max-width: 48ch; }
  .actions { justify-self: end; }

  @media (max-width: 800px) {
    .inner { grid-template-columns: 1fr; }
    .actions { justify-self: start; }
  }
</style>
