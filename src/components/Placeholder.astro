---
// A clean labelled slot for photography that hasn't been commissioned yet.
interface Props {
  label?: string;
  ratio?: string;
  /** dark variant for slate sections */
  dark?: boolean;
}
const { label = 'Insert image', ratio = '16 / 10', dark = false } = Astro.props;
---

<div class:list={['ph', { dark }]} style={`aspect-ratio: ${ratio};`} role="img" aria-label={`Placeholder: ${label}`}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="1" />
    <circle cx="8.5" cy="8.5" r="1.5" />
    <path d="m21 15-5-5L5 21" />
  </svg>
  <span>{label}</span>
</div>

<style>
  .ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    border: 1.5px dashed #b8c6ca;
    background:
      linear-gradient(135deg, rgba(47, 71, 82, 0.035) 25%, transparent 25%, transparent 50%, rgba(47, 71, 82, 0.035) 50%, rgba(47, 71, 82, 0.035) 75%, transparent 75%) 0 0 / 28px 28px,
      #eef1f2;
    color: #7d939a;
  }
  .ph svg { width: 30px; height: 30px; }
  .ph span {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .ph.dark {
    border-color: rgba(255, 255, 255, 0.28);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, 0.04) 50%, rgba(255, 255, 255, 0.04) 75%, transparent 75%) 0 0 / 28px 28px,
      rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.55);
  }
</style>
