---
// Smart image slot. Shows a labelled "insert image" box until a photo with a
// matching filename is dropped into src/assets/uploads/ — e.g. the slot
// <Placeholder name="home-hero" /> is filled by src/assets/uploads/home-hero.jpg
// (or .jpeg/.png/.webp). See README "Adding photos".
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** slot id — matched against filenames in src/assets/uploads/ */
  name?: string;
  label?: string;
  alt?: string;
  ratio?: string;
  /** dark variant for slate sections */
  dark?: boolean;
}
const { name, label = 'Insert image', alt = '', ratio = '16 / 10', dark = false } = Astro.props;

const uploads = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/uploads/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);
let img: ImageMetadata | undefined;
if (name) {
  for (const [path, mod] of Object.entries(uploads)) {
    const base = path.split('/').pop()!.replace(/\.[^.]+$/, '').toLowerCase();
    if (base === name.toLowerCase()) {
      img = mod.default;
      break;
    }
  }
}
---

{
  img ? (
    <div class="slot" style={`aspect-ratio: ${ratio};`}>
      <Image src={img} alt={alt} widths={[480, 960, 1440]} sizes="(min-width: 960px) 50vw, 100vw" />
    </div>
  ) : (
    <div class:list={['ph', { dark }]} style={`aspect-ratio: ${ratio};`} role="img" aria-label={`Placeholder: ${label}`}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="8.5" cy="8.5" r="1.5" />
        <path d="m21 15-5-5L5 21" />
      </svg>
      <span>{label}</span>
      {name && <code>{name}.jpg</code>}
    </div>
  )
}

<style>
  .slot {
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .slot :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    border: 1.5px dashed rgba(255, 255, 255, 0.28);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, 0.04) 50%, rgba(255, 255, 255, 0.04) 75%, transparent 75%) 0 0 / 28px 28px,
      rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.55);
  }
  .ph svg { width: 30px; height: 30px; }
  .ph span {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .ph code {
    font-size: 0.72rem;
    opacity: 0.75;
  }
  .ph.dark {
    border-color: rgba(255, 255, 255, 0.28);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.04) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, 0.04) 50%, rgba(255, 255, 255, 0.04) 75%, transparent 75%) 0 0 / 28px 28px,
      rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.55);
  }
</style>
