---
import { href } from '../lib/paths';
import Placeholder from './Placeholder.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'insights'>;
}
const { post } = Astro.props;
const { title, description, category } = post.data;
---

<a class="post" href={href(`/insights/${post.id}/`)} data-reveal>
  <div class="thumb">
    <Placeholder label="Insert image" ratio="16 / 10" />
  </div>
  <div class="meta">
    <span class="cat">{category}</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
  .post {
    display: block;
    background: #fff;
    border: 1px solid var(--line);
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .post:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(26, 41, 48, 0.12);
    }
  }
  .meta { padding: 26px 26px 30px; }
  .cat {
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--gold-deep);
  }
  h3 {
    font-size: 1.18rem;
    margin: 10px 0;
    line-height: 1.25;
  }
  p { font-size: 0.92rem; }
</style>
