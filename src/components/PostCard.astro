---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'insights'>;
}
const { post } = Astro.props;
const { title, description, category, image, imageAlt } = post.data;
---

<a class="post" href={`/insights/${post.id}/`} data-reveal>
  <div class="thumb">
    <Image src={image} alt={imageAlt} widths={[480, 800]} sizes="(min-width: 800px) 33vw, 100vw" />
  </div>
  <div class="meta">
    <span class="cat">{category}</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
  .post {
    display: block;
    background: #fff;
    border: 1px solid var(--line);
    transition: border-color 0.2s ease;
    color: inherit;
  }
  .post:hover { border-color: var(--gold); }
  .thumb { aspect-ratio: 16 / 10; overflow: hidden; }
  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .post:hover .thumb :global(img) { transform: scale(1.04); }
  }
  .meta { padding: 26px 26px 30px; }
  .cat {
    text-transform: uppercase;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: var(--gold-deep);
  }
  h3 {
    font-size: 1.18rem;
    margin: 10px 0;
    font-weight: 560;
    line-height: 1.3;
  }
  p { font-size: 0.92rem; }
</style>
