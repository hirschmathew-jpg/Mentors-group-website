---
// Scrolling service-links marquee. Pauses while hovered or keyboard-focused,
// always resumes afterwards; wraps statically under prefers-reduced-motion.
const services = [
  { label: 'Audit & Assurance', url: 'https://www.hlb.ie/services/audit-assurance/' },
  { label: 'Taxation', url: 'https://www.hlb.ie/services/taxation/' },
  { label: 'Business Advisory', url: 'https://www.hlb.ie/services/business-advisory/' },
  { label: 'Corporate Finance', url: 'https://www.hlb.ie/services/corporate-finance-2/' },
  { label: 'Outsourcing & Payroll', url: 'https://www.hlb.ie/services/outsourcing/' },
  { label: 'Cyber Security', url: 'https://futurerange.ie/services/security/' },
  { label: 'Modern Workplace', url: 'https://futurerange.ie/services/managed-services/' },
  { label: 'Cloud, AI & Transformation', url: 'https://futurerange.ie/services/future-innovation/' },
];
---

<div class="strip" aria-label="Group services">
  <div class="marquee">
    {[0, 1].map((copy) => (
      <div class="marquee-track" aria-hidden={copy === 1 ? 'true' : undefined}>
        {services.map((s) => (
          <>
            <a href={s.url} target="_blank" rel="noopener noreferrer" tabindex={copy === 1 ? -1 : 0}>{s.label}</a>
            <span class="diamond" aria-hidden="true">◆</span>
          </>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .strip {
    background: var(--ink-deep);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }
  .marquee {
    display: flex;
    width: max-content;
  }
  .marquee-track {
    display: flex;
    align-items: center;
    gap: 34px;
    padding: 18px 17px;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a3b7bd;
    white-space: nowrap;
  }
  @media (prefers-reduced-motion: no-preference) {
    .marquee { animation: ticker 36s linear infinite; }
    .strip:hover .marquee,
    .strip:has(:focus-visible) .marquee { animation-play-state: paused; }
  }
  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee { flex-wrap: wrap; width: auto; }
    .marquee-track[aria-hidden='true'] { display: none; }
    .marquee-track { flex-wrap: wrap; }
  }
  .diamond { color: var(--gold); font-size: 0.55rem; }
  .marquee-track .diamond:nth-of-type(even) { color: var(--teal-bright); }
  .marquee-track a {
    color: #a3b7bd;
    text-underline-offset: 4px;
    padding: 6px 0;
  }
  .marquee-track a:hover {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: var(--gold);
  }
</style>
