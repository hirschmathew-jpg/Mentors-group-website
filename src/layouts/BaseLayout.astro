---
import { ClientRouter } from 'astro:transitions';
import { href } from '../lib/paths';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** og:type, defaults to website */
  type?: string;
  /** optional page-specific JSON-LD (e.g. Article schema) */
  jsonld?: Record<string, unknown>;
}

const { title, description, type = 'website', jsonld } = Astro.props;
// The 404 page has no canonical URL of its own — don't emit one for it.
const is404 = Astro.url.pathname.includes('/404');
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(href('/og.png'), Astro.site);
const siteUrl = new URL(href('/'), Astro.site).href;

// Sitewide Organization graph — Mentora Group and the two firms it holds.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Mentora Group',
  url: siteUrl,
  logo: ogImage.href,
  description:
    'Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Suite 7, The Courtyard, Carmanhall Road, Sandyford',
    addressLocality: 'Dublin',
    postalCode: 'D18 NW62',
    addressCountry: 'IE',
  },
  subOrganization: [
    { '@type': 'Organization', name: 'HLB Ireland', url: 'https://www.hlb.ie' },
    { '@type': 'Organization', name: 'FutureRange', url: 'https://www.futurerange.ie' },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {!is404 && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />
    <link rel="sitemap" href={href('/sitemap-index.xml')} />
    <meta name="theme-color" content="#1a2930" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Mentora Group" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {!is404 && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}

    <link rel="preload" href={href('/fonts/fraunces.woff2')} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={href('/fonts/manrope.woff2')} as="font" type="font/woff2" crossorigin />

    <script is:inline>
      // Mark the document as JS-capable. The ClientRouter swap replaces the
      // <html> attributes from the incoming static page, so re-add the class
      // after every view transition or the no-JS fallbacks kick back in.
      document.documentElement.classList.add('js');
      document.addEventListener('astro:after-swap', () => document.documentElement.classList.add('js'));
    </script>
    <ClientRouter />
  </head>
  <body>
    <div id="scroll-progress" aria-hidden="true"></div>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Site motion engine. Everything is progressive enhancement — content is
      // fully visible without JS — and re-initialises after view transitions.
      const reduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function initReveals() {
        const items = document.querySelectorAll('[data-reveal]:not(.revealed)');
        if (reduced()) {
          items.forEach((el) => el.classList.add('revealed'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            let i = 0;
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              const el = entry.target as HTMLElement;
              el.style.transitionDelay = `${Math.min(i * 80, 320)}ms`;
              el.classList.add('revealed');
              io.unobserve(el);
              i++;
            }
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        items.forEach((el) => io.observe(el));
      }

      function initCountups() {
        const els = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-counted])');
        if (!els.length || reduced()) return;
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              io.unobserve(entry.target);
              const el = entry.target as HTMLElement;
              el.dataset.counted = 'true';
              const target = parseInt(el.dataset.countup || '0', 10);
              const suffix = el.dataset.suffix || '';
              const start = performance.now();
              const dur = 1400;
              const tick = (now: number) => {
                const p = Math.min((now - start) / dur, 1);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.round(eased * target) + suffix;
                if (p < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            }
          },
          { threshold: 0.4 }
        );
        els.forEach((el) => io.observe(el));
      }

      // Bound once; survives view transitions.
      let scrollBound = false;
      function initScrollFx() {
        if (scrollBound) return;
        scrollBound = true;
        const onScroll = () => {
          const bar = document.getElementById('scroll-progress');
          const header = document.querySelector('.site-header');
          const max = document.documentElement.scrollHeight - window.innerHeight;
          if (bar) bar.style.width = max > 0 ? `${(window.scrollY / max) * 100}%` : '0%';
          if (header) header.classList.toggle('scrolled', window.scrollY > 20);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        document.addEventListener('astro:page-load', onScroll);
      }

      const finePointer = () => window.matchMedia('(pointer: fine)').matches;

      function initMicro() {
        if (reduced() || !finePointer()) return;
        // cursor-following glow on every main section (not the services strip)
        const glowSel =
          '.hero, .firms, .trust, .approach, .voices, .insights, .legacy, .cta, ' +
          '.page-hero, .story, .tl, .listing, .contact, .legal, .pitch, .record, .confidential, .related';
        document.querySelectorAll<HTMLElement>(glowSel).forEach((band) => {
          if (band.dataset.glow) return;
          band.dataset.glow = 'true';
          band.classList.add('glow-host');
          const glow = document.createElement('i');
          glow.className = 'cursor-glow';
          glow.setAttribute('aria-hidden', 'true');
          band.appendChild(glow);
          band.addEventListener('pointermove', (e) => {
            const r = band.getBoundingClientRect();
            glow.style.setProperty('--mx', `${e.clientX - r.left}px`);
            glow.style.setProperty('--my', `${e.clientY - r.top}px`);
          });
        });
        // magnetic gold buttons
        document.querySelectorAll<HTMLElement>('.btn-gold').forEach((btn) => {
          if (btn.dataset.magnet) return;
          btn.dataset.magnet = 'true';
          btn.addEventListener('pointermove', (e) => {
            const r = btn.getBoundingClientRect();
            const dx = (e.clientX - r.left - r.width / 2) / r.width;
            const dy = (e.clientY - r.top - r.height / 2) / r.height;
            btn.style.translate = `${dx * 8}px ${dy * 6}px`;
          });
          btn.addEventListener('pointerleave', () => (btn.style.translate = ''));
        });
        // orbit tilt
        const orbit = document.querySelector<HTMLElement>('.orbit');
        const hero = document.querySelector<HTMLElement>('.hero');
        if (orbit && hero && !orbit.dataset.tilt) {
          orbit.dataset.tilt = 'true';
          hero.addEventListener('pointermove', (e) => {
            const r = hero.getBoundingClientRect();
            const dx = (e.clientX - r.left) / r.width - 0.5;
            const dy = (e.clientY - r.top) / r.height - 0.5;
            orbit.style.transform = `perspective(900px) rotateY(${dx * 7}deg) rotateX(${dy * -7}deg)`;
          });
          hero.addEventListener('pointerleave', () => (orbit.style.transform = ''));
        }
      }

      document.addEventListener('astro:page-load', () => {
        initReveals();
        initCountups();
        initScrollFx();
        initMicro();
        // ambient videos obey reduced-motion
        document.querySelectorAll<HTMLVideoElement>('video[data-ambient]').forEach((v) => {
          if (reduced()) { v.pause(); v.style.display = 'none'; }
          else v.play().catch(() => {});
        });
      });
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--gold);
        color: var(--ink);
        padding: 0.8rem 1.2rem;
        font-weight: 700;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0;
      }
      #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        width: 0;
        background: linear-gradient(90deg, var(--gold), #f6d67c);
        z-index: 60;
      }
    </style>
  </body>
</html>
