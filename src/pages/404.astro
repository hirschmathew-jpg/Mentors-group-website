---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Mentora Group"
  description="The page you were looking for could not be found."
>
  <section class="page-hero on-dark nf">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>That page isn't here</h1>
      <p class="lede">
        The page you're looking for may have moved or never existed. Try the
        homepage, or get in touch and we'll point you the right way.
      </p>
      <div class="actions">
        <a class="btn btn-gold" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/contact/">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding: 140px 0 160px; }
  .actions { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 34px; }
</style>
