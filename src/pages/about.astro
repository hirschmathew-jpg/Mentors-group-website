---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';

import sandyfordOffice from '../assets/photos/sandyford-office.webp';

---

<BaseLayout
  title="About — Mentora Group"
  description="Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm — two established firms, one group."
>
  <!-- Page hero -->
  <section class="page-hero on-dark">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">About Mentora</p>
        <h1>Two firms. Five decades. One group.</h1>
        <p class="lede">
          Mentora Group is the holding company of HLB Ireland, an audit,
          accounting and tax advisory firm, and FutureRange, an IT services
          firm — five decades of experience serving business across Ireland.
        </p>
      </div>
      <div class="hero-media">
        <Image
          src={sandyfordOffice}
          alt="The Mentora Group office in Sandyford, Dublin"
          widths={[640, 960, 1280]}
          sizes="(min-width: 960px) 42vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="story">
    <div class="container">
      <div data-reveal>
        <p class="eyebrow">Our story</p>
        <h2 class="section-title">Built on decades of trust</h2>
        <div class="body">
          <p>
            HLB Ireland was established in 1976 and is headquartered in Dublin
            — a full-service advisory and accounting firm of 180 professionals,
            where every assignment is partner-led.
          </p>
          <p>
            FutureRange was founded in 1995 by entrepreneur Tom Haugh — three
            decades of managed IT, cybersecurity and digital transformation,
            today an all-island business.
          </p>
          <p>
            Formed in 2026, Mentora Group is the holding company that brings
            them together — and the structure through which the group will
            continue to grow.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  .hero-media :global(img) {
    width: 100%;
    height: auto;
    clip-path: polygon(10% 0, 100% 0, 100% 100%, 0 100%);
  }

  .story { padding: 110px 0; }
  .story h2 { margin-bottom: 26px; }
  .story .body p { max-width: 62ch; }
  .story .body p + p { margin-top: 18px; }


  @media (prefers-reduced-motion: no-preference) {
    }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-media :global(img) { clip-path: none; }
  }
</style>
