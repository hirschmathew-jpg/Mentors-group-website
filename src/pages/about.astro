---
import { href } from '../lib/paths';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import Placeholder from '../components/Placeholder.astro';
import ServicesStrip from '../components/ServicesStrip.astro';

const timeline = [
  { year: '1976', title: 'HLB Ireland founded', text: 'Partner-led audit, accounting and tax advisory, headquartered in Dublin.' },
  { year: '1995', title: 'FutureRange founded', text: 'Tom Haugh sets out to help businesses get real value from technology.' },
  { year: '2019', title: 'First major merger', text: 'Conlan Crotty Murray joins — the acquisition programme begins.' },
  { year: '2025', title: 'Cardinal Capital invests', text: 'Minority backing accelerates growth: six acquisitions follow in fourteen months.' },
  { year: '2026', title: 'Mentora Group formed', text: 'One group holds both firms — 12 acquisitions in, 180+ professionals strong.' },
];
---

<BaseLayout
  title="About — Mentora Group"
  description="Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm — one group, two independent firms."
>
  <!-- Page hero -->
  <section class="page-hero on-dark">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">About Mentora</p>
        <h1>The group behind the firms<span class="dot">.</span></h1>
        <p class="lede">
          One group, two independent firms, every discipline an ambitious
          business needs — that is Mentora Group.
        </p>
      </div>
      <div class="hero-media">
        <Placeholder name="about-hero" label="Insert image" ratio="4 / 3" dark />
      </div>
    </div>
  </section>

  <!-- Service strip (marquee) -->
  <ServicesStrip />

  <!-- Story -->
  <section class="story">
    <div class="container story-grid">
      <div data-reveal>
        <p class="eyebrow">Our story</p>
        <h2 class="section-title title-accent">Why Mentora exists</h2>
        <div class="body">
          <p>
            Mentora Group was formed in 2026 to bring two of Ireland's
            established firms under one roof: HLB Ireland, the
            Dublin-headquartered audit, accounting and tax advisory firm
            founded in 1976, and FutureRange, the IT services firm founded in
            1995 and now operating across the island of Ireland.
          </p>
          <p>
            The group exists for a simple reason: a business's finances and
            its technology increasingly depend on each other, and almost
            nobody handles both well. HLB Ireland brings 180 partner-led
            professionals. FutureRange brings three decades of cyber security,
            managed IT and cloud. Mentora holds them together — each firm
            keeping its own name, team and clients.
          </p>
          <p>
            Backed by Cardinal Capital since 2025, the group has completed
            twelve acquisitions in seven years — and is built to keep growing.
            {/* JOIN-PAGE: remove this sentence if the join page is removed */}
            If your practice is weighing its future,
            <a href={href('/join-the-group/')}>see what joining looks like</a>.
          </p>
        </div>
      </div>
      <div class="story-media" data-reveal>
        <Placeholder name="about-story" label="Insert image" ratio="3 / 4" />
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="tl band on-dark">
    <div class="container">
      <div data-reveal>
        <p class="eyebrow">Timeline</p>
        <h2 class="section-title title-accent">How the group came together</h2>
      </div>
      <ol class="tl-rail">
        {timeline.map((item) => (
          <li class="tl-item" data-reveal>
            <span class="tl-node" aria-hidden="true"></span>
            <span class="tl-year">{item.year}</span>
            <span class="tl-title">{item.title}</span>
            <span class="tl-text">{item.text}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  h1 .dot { color: var(--gold); }

  .story { padding: 110px 0; }
  .story-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: start;
  }
  .story h2 { margin-bottom: 26px; }
  .story .body p { max-width: 62ch; }
  .story .body p + p { margin-top: 18px; }
  .story .body a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .story .body a:hover { color: var(--gold-deep); }

  /* timeline — gradient rail with glowing nodes */
  .tl { padding: 100px 0; position: relative; overflow: hidden; }
  .tl-rail {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 28px;
    margin-top: 64px;
    position: relative;
    padding: 0;
  }
  .tl-rail::before {
    content: "";
    position: absolute;
    top: 7px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--teal-bright), var(--violet));
    opacity: 0.65;
  }
  .tl-item { position: relative; padding-top: 34px; }
  .tl-node {
    position: absolute;
    top: 0;
    left: 0;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 5px rgba(234, 182, 51, 0.18);
  }
  .tl-item:nth-child(2) .tl-node { background: var(--teal-bright); box-shadow: 0 0 0 5px rgba(59, 191, 208, 0.18); }
  .tl-item:nth-child(3) .tl-node { background: var(--gold); }
  .tl-item:nth-child(4) .tl-node { background: var(--teal-bright); box-shadow: 0 0 0 5px rgba(59, 191, 208, 0.18); }
  .tl-item:nth-child(5) .tl-node { background: var(--violet); box-shadow: 0 0 0 5px rgba(143, 127, 242, 0.2); }
  @media (prefers-reduced-motion: no-preference) {
    .tl-node { animation: pulse 3.2s ease-in-out infinite; }
    .tl-item:nth-child(2) .tl-node { animation-delay: 0.5s; }
    .tl-item:nth-child(3) .tl-node { animation-delay: 1s; }
    .tl-item:nth-child(4) .tl-node { animation-delay: 1.5s; }
    .tl-item:nth-child(5) .tl-node { animation-delay: 2s; }
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.25); }
  }
  .tl-year {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
  }
  .tl-item:nth-child(2) .tl-year { color: var(--teal-bright); }
  .tl-item:nth-child(4) .tl-year { color: var(--teal-bright); }
  .tl-item:nth-child(5) .tl-year { color: var(--violet-ink); }
  .tl-title {
    display: block;
    font-weight: 800;
    color: #f0f4f5;
    margin-bottom: 8px;
  }
  .tl-text { display: block; font-size: 0.9rem; color: var(--muted-on-dark); }

  @media (max-width: 900px) {
    .hero-grid, .story-grid { grid-template-columns: 1fr; }
    .tl-rail {
      grid-template-columns: repeat(5, minmax(230px, 1fr));
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 14px;
      -webkit-overflow-scrolling: touch;
    }
    .tl-item { scroll-snap-align: start; }
  }
</style>
