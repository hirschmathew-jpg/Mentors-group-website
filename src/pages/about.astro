---
import { href } from '../lib/paths';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import Placeholder from '../components/Placeholder.astro';
---

<BaseLayout
  title="About — Mentora Group"
  description="Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm — one group, two independent firms."
>
  <!-- Page hero -->
  <section class="page-hero on-dark">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">About Mentora</p>
        <h1>The group behind the firms<span class="dot">.</span></h1>
        <p class="lede">
          One group, two independent firms, every discipline an ambitious
          business needs — that is Mentora Group.
        </p>
      </div>
      <div class="hero-media">
        <Placeholder name="about-hero" label="Insert image" ratio="4 / 3" dark />
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="story">
    <div class="container story-grid">
      <div data-reveal>
        <p class="eyebrow">Our story</p>
        <h2 class="section-title title-accent">Why Mentora exists</h2>
        <div class="body">
          <p>
            Mentora Group was formed in 2026 to bring two of Ireland's
            established firms under one roof: HLB Ireland, the
            Dublin-headquartered audit, accounting and tax advisory firm
            founded in 1976, and FutureRange, the IT services firm founded in
            1995 and now operating across the island of Ireland.
          </p>
          <p>
            The group exists for a simple reason: a business's finances and
            its technology increasingly depend on each other, and almost
            nobody handles both well. HLB Ireland brings 180 partner-led
            professionals. FutureRange brings three decades of cyber security,
            managed IT and cloud. Mentora holds them together — each firm
            keeping its own name, team and clients.
          </p>
          <p>
            Backed by Cardinal Capital since 2025, the group has completed
            twelve acquisitions in seven years — and is built to keep growing.
            {/* JOIN-PAGE: remove this sentence if the join page is removed */}
            If your practice is weighing its future,
            <a href={href('/join-the-group/')}>see what joining looks like</a>.
          </p>
        </div>
      </div>
      <div class="story-media" data-reveal>
        <Placeholder name="about-story" label="Insert image" ratio="3 / 4" />
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  h1 .dot { color: var(--gold); }

  .story { padding: 110px 0; }
  .story-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: start;
  }
  .story h2 { margin-bottom: 26px; }
  .story .body p { max-width: 62ch; }
  .story .body p + p { margin-top: 18px; }
  .story .body a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .story .body a:hover { color: var(--gold-deep); }

  @media (max-width: 900px) {
    .hero-grid, .story-grid { grid-template-columns: 1fr; }
  }
</style>
