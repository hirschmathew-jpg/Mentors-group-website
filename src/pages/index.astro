---
import { href } from '../lib/paths';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import PostCard from '../components/PostCard.astro';

import teamGroup from '../assets/photos/team-group.webp';
import professionalsDesk from '../assets/photos/professionals-desk.webp';
import teamCollaborating from '../assets/photos/team-collaborating.webp';
import hlbReception from '../assets/photos/hlb-reception.webp';
import futurerangeSign from '../assets/photos/futurerange-sign.webp';

const posts = (await getCollection('insights'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Mentora Group — Your partner in growth"
  description="Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm — serving ambitious businesses across Ireland."
>
  <!-- Hero -->
  <section class="hero band on-dark">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">The Mentora Group</p>
        <h1>Your partner in <em>growth</em></h1>
        <p class="lede">
          Mentora Group is the holding company of HLB Ireland and FutureRange
          — audit, accounting, tax and IT services for ambitious businesses
          across Ireland.
        </p>
        <div class="hero-actions">
          <a class="btn btn-gold" href={href('/contact/')}>Talk to us <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href={href('/about/')}>About the group</a>
        </div>
      </div>
      <div class="hero-media">
        <Image
          src={teamGroup}
          alt="The Mentora Group team"
          widths={[640, 960, 1280]}
          sizes="(min-width: 960px) 45vw, 100vw"
          loading="eager"
          fetchpriority="high"
        />
        <p class="kicker">
          <strong>Two firms. Five decades. One group.</strong>
          Advisory since 1976. Technology since 1995. One group since 2026.
        </p>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="container intro-grid">
      <div data-reveal>
        <p class="eyebrow">Who we are</p>
        <h2 class="section-title">One group. Two established firms.</h2>
        <div class="body">
          <p>
            Mentora Group is the holding company of HLB Ireland, an audit,
            accounting and tax advisory firm working with ambitious domestic
            and international businesses since 1976, and FutureRange, an IT
            services firm providing cyber security, managed services and
            digital transformation since 1995.
          </p>
          <p>
            Each firm keeps the name, team and relationships its clients know.
            Behind them, the group provides shared strength, stability and
            investment for the long term.
          </p>
        </div>
      </div>
      <div class="intro-media" data-reveal>
        <Image
          class="ph-a"
          src={professionalsDesk}
          alt="Mentora Group professionals working together"
          widths={[480, 800]}
          sizes="(min-width: 960px) 32vw, 80vw"
        />
        <Image
          class="ph-b"
          src={teamCollaborating}
          alt="Team collaborating in the office"
          widths={[400, 640]}
          sizes="(min-width: 960px) 20vw, 50vw"
        />
      </div>
    </div>
  </section>

  <!-- Firms -->
  <section class="firms">
    <div class="container">
      <div class="firms-head" data-reveal>
        <div>
          <p class="eyebrow">Our firms</p>
          <h2 class="section-title">One group, two specialisms</h2>
        </div>
        <p>
          Audit, accounting, tax, cyber security, managed IT and digital
          transformation — a comprehensive offering across the group.
        </p>
      </div>
      <div class="firm-cards">
        <a class="firm" href="https://www.hlb.ie" rel="noopener" data-reveal>
          <Image
            src={hlbReception}
            alt="The HLB Ireland office reception"
            widths={[640, 960, 1280]}
            sizes="(min-width: 800px) 48vw, 100vw"
          />
          <span class="firm-label">
            <span class="tag">Audit, Accounting &amp; Tax</span>
            <span class="name">HLB Ireland <span class="go" aria-hidden="true">→</span></span>
            <span class="desc">Audit &amp; assurance, accounting, taxation and business advisory — since 1976.</span>
          </span>
        </a>
        <a class="firm" href="https://www.futurerange.ie" rel="noopener" data-reveal>
          <Image
            src={futurerangeSign}
            alt="FutureRange office signage"
            widths={[640, 960, 1280]}
            sizes="(min-width: 800px) 48vw, 100vw"
          />
          <span class="firm-label">
            <span class="tag">Managed IT, Security &amp; Digital</span>
            <span class="name">FutureRange <span class="go" aria-hidden="true">→</span></span>
            <span class="desc">Cyber security &amp; managed operations, modern workplace, and cloud, AI &amp; transformation — since 1995.</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Legacy: quote + stats -->
  <section class="legacy band on-dark">
    <div class="container">
      <div class="legacy-head" data-reveal>
        <p class="eyebrow">The group</p>
        <h2 class="section-title">Established expertise, held for the long term</h2>
        <p class="legacy-sub">
          Mentora exists to give both firms a permanent home — with the backing
          to invest, acquire and grow, while every client keeps the team they
          trust.
        </p>
      </div>
      <dl class="stats" data-reveal>
        <div class="stat"><dt>HLB Ireland founded</dt><dd>1976</dd></div>
        <div class="stat"><dt>FutureRange established</dt><dd>1995</dd></div>
        <div class="stat"><dt>Acquisitions in the past seven years</dt><dd>12</dd></div>
        <div class="stat"><dt>Professionals across the group</dt><dd>180+</dd></div>
      </dl>
    </div>
  </section>

  <!-- Approach -->
  <section class="approach">
    <div class="container">
      <div class="approach-head" data-reveal>
        <p class="eyebrow">How we work</p>
        <h2 class="section-title">What the group gets you in practice</h2>
      </div>
      <div class="pillars" data-reveal>
        <div class="pillar">
          <div class="glyph" aria-hidden="true"></div>
          <h3>Finance and IT at one table</h3>
          <p>
            The same group holds your accountants and your IT provider. When a
            question spans both — systems for a new entity, security around
            financial data, technology due diligence on a deal — HLB Ireland
            and FutureRange work it together, and you deal with one group.
          </p>
        </div>
        <div class="pillar">
          <div class="glyph" aria-hidden="true"></div>
          <h3>Partner-led, not passed down</h3>
          <p>
            Every HLB Ireland assignment is led by a partner — you deal
            directly with the person responsible for your work, with 180
            professionals behind them when the job needs scale.
          </p>
        </div>
        <div class="pillar">
          <div class="glyph" aria-hidden="true"></div>
          <h3>A home for good practices</h3>
          <p>
            Twelve practices have joined the group in seven years, and we
            remain open to more where the fit is right. Planning succession or
            the sale of your practice? <a href={href('/contact/')}>Talk to us
            in confidence</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Insights -->
  <section class="insights">
    <div class="container">
      <div class="insights-head" data-reveal>
        <div>
          <p class="eyebrow">Insights</p>
          <h2 class="section-title">Latest from the group</h2>
        </div>
        <a class="all-link" href={href('/insights/')}>All insights</a>
      </div>
      <div class="posts">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  /* hero */
  .hero { overflow: hidden; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
    gap: 56px;
    padding-top: 84px;
    padding-bottom: 92px;
  }
  h1 {
    color: #f6f5fa;
    font-size: clamp(2.6rem, 5.2vw, 4.1rem);
    font-weight: 480;
    letter-spacing: -0.01em;
    margin-bottom: 26px;
    max-width: 12ch;
  }
  h1 em { font-style: italic; color: var(--gold); }
  .lede {
    font-size: 1.12rem;
    max-width: 46ch;
    margin-bottom: 38px;
  }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-media { position: relative; }
  .hero-media :global(img) {
    width: 100%;
    height: auto;
    clip-path: polygon(10% 0, 100% 0, 100% 100%, 0 100%);
  }
  .kicker {
    position: absolute;
    bottom: -22px;
    right: -12px;
    background: var(--ink-deep);
    border-left: 3px solid var(--gold);
    padding: 16px 22px;
    max-width: 300px;
    color: #dce7ea;
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .kicker strong { color: #fff; display: block; font-size: 0.95rem; }

  /* intro */
  .intro { padding: 110px 0 90px; }
  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 72px;
    align-items: start;
  }
  .intro h2 { margin-bottom: 26px; }
  .intro .body p { max-width: 62ch; }
  .intro .body p + p { margin-top: 18px; }
  .intro-media { position: relative; padding-bottom: 46px; }
  .intro-media :global(.ph-a) { width: 82%; }
  .intro-media :global(.ph-b) {
    width: 52%;
    position: absolute;
    right: 0;
    bottom: 0;
    border: 6px solid var(--paper);
  }
  .intro-media::before {
    content: "";
    position: absolute;
    top: -18px;
    left: -18px;
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, var(--gold) 49.5%, transparent 50%);
    opacity: 0.9;
  }

  /* firms */
  .firms { padding: 40px 0 110px; }
  .firms-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 44px;
  }
  .firms-head p { max-width: 42ch; }
  .firm-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  .firm {
    position: relative;
    display: block;
    min-height: 380px;
    overflow: hidden;
    color: #fff;
    background: var(--ink);
  }
  .firm :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9);
  }
  @media (prefers-reduced-motion: no-preference) {
    .firm :global(img) { transition: transform 0.5s ease; }
    .firm:hover :global(img) { transform: scale(1.035); }
  }
  .firm::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(6deg, rgba(28, 42, 49, 0.92) 18%, rgba(28, 42, 49, 0.25) 60%, rgba(28, 42, 49, 0.05));
  }
  .firm-label {
    position: absolute;
    z-index: 2;
    left: 34px;
    right: 34px;
    bottom: 30px;
  }
  .firm-label .tag {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--gold);
    display: block;
    margin-bottom: 8px;
  }
  .firm-label .name {
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 520;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .firm-label .go {
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 400;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    display: grid;
    place-items: center;
    border-radius: 999px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .firm:hover .go {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--ink);
  }
  .firm-label .desc {
    color: #c9d6da;
    font-size: 0.95rem;
    max-width: 46ch;
    margin-top: 10px;
    display: block;
  }

  /* legacy */
  .legacy { padding: 96px 0; }
  .legacy-head { max-width: 640px; margin-bottom: 64px; }
  .legacy-head h2 { margin-bottom: 16px; }
  .legacy-sub { color: var(--muted-on-dark); }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 34px;
    border-top: 1px solid var(--hairline-band);
    padding-top: 48px;
  }
  /* column-reverse puts the number above its label; flex-end packs the
     stack to the cell's top so all numbers align regardless of label wrap */
  .stat { display: flex; flex-direction: column-reverse; justify-content: flex-end; }
  .stat dd {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
  }
  .stat dt {
    margin-top: 10px;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--muted-on-dark);
    max-width: 20ch;
  }

  /* approach */
  .approach { padding: 110px 0; }
  .approach-head { max-width: 640px; margin-bottom: 56px; }
  .approach-head h2 { margin-bottom: 18px; }
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--line);
    background: #fff;
  }
  .pillar { padding: 44px 38px; border-left: 1px solid var(--line); }
  .pillar:first-child { border-left: none; }
  .glyph {
    width: 46px;
    height: 46px;
    margin-bottom: 22px;
    background: linear-gradient(135deg, var(--gold) 49.5%, transparent 50%);
  }
  .pillar h3 { font-size: 1.25rem; margin-bottom: 12px; font-weight: 560; }
  .pillar p { font-size: 0.95rem; }
  .pillar a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pillar a:hover { color: var(--gold-deep); }

  /* insights */
  .insights { padding: 0 0 110px; }
  .insights-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 44px;
  }
  .all-link {
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--head);
    border-bottom: 2px solid var(--gold);
    padding-bottom: 4px;
  }
  .all-link:hover { color: var(--gold-deep); }
  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  @media (max-width: 960px) {
    .hero-grid, .intro-grid, .firm-cards { grid-template-columns: 1fr; }
    .hero-media :global(img) { clip-path: none; }
    .kicker { position: static; margin-top: 14px; max-width: none; }
    .stats { grid-template-columns: 1fr 1fr; }
    .pillars { grid-template-columns: 1fr; }
    .pillar { border-left: none; border-top: 1px solid var(--line); }
    .pillar:first-child { border-top: none; }
    .posts { grid-template-columns: 1fr; }
    .firms-head { flex-direction: column; align-items: flex-start; }
  }
</style>
