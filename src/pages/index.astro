  .voice .firm-tag {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-deep);
  }
  .voice.fr .firm-tag { color: var(--teal-ink); }

  /* numbers — darker blue band */
  .legacy { padding: 100px 0; position: relative; overflow: hidden; background: var(--paper); }
  .legacy::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(720px 420px at 88% 80%, rgba(234, 182, 51, 0.1), transparent 65%);
    pointer-events: none;
  }
  .legacy .container { position: relative; }
  .legacy-head { max-width: 760px; margin-bottom: 64px; }
  .legacy-quote blockquote {
    font-family: var(--font-serif);
    font-weight: 460;
    font-size: clamp(1.5rem, 2.9vw, 2.3rem);
    line-height: 1.4;
    color: #f0f4f5;
    letter-spacing: 0;
    max-width: 28ch;
  }
  .legacy-quote em {
    font-style: italic;
    color: var(--gold);
  }
  .legacy-quote figcaption {
    margin-top: 16px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-on-dark);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 34px;
    border-top: 1px solid var(--hairline-band);
    padding-top: 48px;
  }
  .stat { display: flex; flex-direction: column-reverse; justify-content: flex-end; }
  .stat dd {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.8rem, 4.6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--gold);
    line-height: 1;
  }
  .stat dt {
