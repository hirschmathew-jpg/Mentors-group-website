  .voices-head > div:first-child { max-width: 640px; }
  .voices-nav { display: flex; gap: 10px; }
  .v-btn {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--head);
    display: grid;
    place-items: center;
