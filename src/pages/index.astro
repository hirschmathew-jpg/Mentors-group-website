---
import { href } from '../lib/paths';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import PostCard from '../components/PostCard.astro';
import Placeholder from '../components/Placeholder.astro';
import ServicesStrip from '../components/ServicesStrip.astro';

// Drop hero-video.mp4 into src/assets/uploads/ for a full-bleed hero video.
const videos = import.meta.glob<string>('../assets/uploads/hero-video.mp4', {
  eager: true,
  query: '?url',
  import: 'default',
});
const heroVideo = Object.values(videos)[0];

const posts = (await getCollection('insights'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Credentials — all verifiable from the firms' own sites.
const credentials = [
  { main: '1976 & 1995', sub: 'Two firms, five decades' },
  { main: 'Registered Auditors', sub: 'Chartered Accountants Ireland' },
  { main: 'Great Place to Work®', sub: 'Certified' },
  { main: 'Most Loved Workplace®', sub: 'Two years running' },
  { main: 'HLB Global', sub: 'Network across 155 countries' },
];

// Real client testimonials from FutureRange's website.
const testimonials = [
  {
    quote:
      'FutureRange planned and executed our move to Office 365 meticulously. I have moved my IT support to FutureRange and found them equally impressive and very knowledgeable on all aspects of IT.',
    who: 'Paul Dunne',
    org: 'Hisun Technologies',
  },
  {
    quote:
      'FutureRange provided immensely beneficial knowledge transfer to our IT professionals and staff. We feel a very high level of trust and confidence with FutureRange now and into the future.',
    who: 'Head of IT',
    org: 'Zenith Technologies',
  },
  {
    quote:
      'I have always found the staff in FutureRange pleasant to deal with and very responsive to any IT issues we have.',
    who: 'Margaret Wafer',
    org: 'Director of Nursing, Belmont House',
  },
];
---

<BaseLayout
  title="Mentora Group — Audit. Advisory. Technology. One group."
  description="Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm — serving ambitious businesses across Ireland."
>
  <!-- Hero -->
  <section class="hero band on-dark">
    {heroVideo && <video class="hero-video" data-ambient src={heroVideo} autoplay muted loop playsinline preload="metadata" aria-hidden="true"></video>}
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">The Mentora Group</p>
        <h1>
          <span class="line">
            <span class="w" style="--d: 0.1s">Accounting<span class="dot">.</span></span>
            <span class="w" style="--d: 0.22s">Advisory<span class="dot">.</span></span>
            <span class="w" style="--d: 0.34s">Technology<span class="dot">.</span></span>
          </span>
          <span class="line">
            <span class="w sheen" style="--d: 0.5s">One group<span class="dot">.</span></span>
          </span>
        </h1>
        <p class="lede">
          Mentora Group is the holding company of HLB Ireland and FutureRange
          — 180+ professionals across audit, accounting, tax and IT, for
          ambitious businesses across Ireland.
        </p>
        <div class="hero-actions">
          <a class="btn btn-gold" href={href('/contact/')}>Talk to us <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href={href('/about/')}>About the group</a>
        </div>
      </div>
      <div class="hero-media">
        <div class="orbit" aria-label="Group highlights">
          <div class="orbit-ring" aria-hidden="true"></div>
          <div class="orbit-mask">
            <div class="orbit-track">
              <Placeholder name="hero-carousel-1" label="Insert image" ratio="1 / 1" dark />
              <Placeholder name="hero-carousel-2" label="Insert image" ratio="1 / 1" dark />
              <Placeholder name="hero-carousel-3" label="Insert image" ratio="1 / 1" dark />
              <Placeholder name="hero-carousel-4" label="Insert image" ratio="1 / 1" dark />
              <Placeholder name="hero-carousel-1" label="Insert image" ratio="1 / 1" dark />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service strip (marquee) -->
  <ServicesStrip />

  <!-- Firms -->
  <section class="firms">
    <div class="container">
      <div class="firms-head" data-reveal>
        <div>
          <p class="eyebrow">Who we are</p>
          <h2 class="section-title title-accent">One group. Two established firms.</h2>
        </div>
        <div class="firms-copy">
          <p>
            Mentora Group is the holding company of HLB Ireland — audit,
            accounting and tax advisory since 1976 — and FutureRange, IT
            services since 1995.
          </p>
          <p>
            Each firm keeps the name, team and relationships its clients know;
            the group behind them provides stability and long-term investment.
          </p>
        </div>
      </div>
      <div class="firm-cards">
        <a class="firm" href="https://www.hlb.ie" target="_blank" rel="noopener noreferrer" data-reveal>
          <Placeholder name="firm-hlb" label="Insert image" ratio="16 / 9" />
          <span class="firm-body">
            <span class="tag">Audit, Accounting &amp; Tax</span>
            <span class="name">HLB Ireland <span class="go" aria-hidden="true">→</span></span>
            <span class="desc">Audit &amp; assurance, taxation, business advisory, corporate finance and outsourcing — since 1976.</span>
          </span>
        </a>
        <a class="firm firm-teal" href="https://www.futurerange.ie" target="_blank" rel="noopener noreferrer" data-reveal>
          <Placeholder name="firm-futurerange" label="Insert image" ratio="16 / 9" />
          <span class="firm-body">
            <span class="tag">Managed IT, Security &amp; Digital</span>
            <span class="name">FutureRange <span class="go" aria-hidden="true">→</span></span>
            <span class="desc">Cyber security &amp; managed operations, modern workplace, and cloud, AI &amp; transformation — since 1995.</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust / accreditations -->
  <section class="trust" aria-label="Credentials">
    <div class="container trust-inner" data-reveal>
      {credentials.map((c) => (
        <div class="cred">
          <span class="cred-main">{c.main}</span>
          <span class="cred-sub">{c.sub}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- How we work -->
  <section class="approach band on-dark">
    <div class="container">
      <div class="approach-head" data-reveal>
        <p class="eyebrow">How we work</p>
        <h2 class="section-title title-accent">What the group gets you in practice</h2>
      </div>
      <div class="pillars" data-reveal>
        <div class="pillar">
          <h3>Finance and IT at one table</h3>
          <p>
            The same group holds your accountants and your IT provider. When a
            question spans both — systems for a new entity, security around
            financial data, technology due diligence on a deal — HLB Ireland
            and FutureRange work it together, and you deal with one group.
          </p>
        </div>
        <div class="pillar">
          <h3>Partner-led, not passed down</h3>
          <p>
            Every HLB Ireland assignment is led by a partner — you deal
            directly with the person responsible for your work, with 180
            professionals behind them when the job needs scale.
          </p>
        </div>
        <div class="pillar">
          <h3>A home for good practices</h3>
          <p>
            Twelve practices have joined the group in seven years, and we
            remain open to more where the fit is right. Planning succession or
            the sale of your practice?
            <a href={href('/join-the-group/')}>Talk to us in confidence</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="voices" aria-label="What clients say">
    <div class="container">
      <div class="voices-head" data-reveal>
        <p class="eyebrow">In their words</p>
        <h2 class="section-title">Trusted by organisations across Ireland</h2>
      </div>
      <div class="voices-grid">
        {testimonials.map((t) => (
          <figure class="voice" data-reveal>
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="who">{t.who}</span>
              <span class="org">{t.org}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Insights -->
  <section class="insights">
    <div class="container">
      <div class="insights-head" data-reveal>
        <div>
          <p class="eyebrow">Insights</p>
          <h2 class="section-title">Latest from the group</h2>
        </div>
        <a class="all-link" href={href('/insights/')}>All insights</a>
      </div>
      <div class="posts">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <!-- The group in numbers -->
  <section class="legacy band on-dark">
    <div class="container">
      <div class="legacy-head" data-reveal>
        <p class="eyebrow">The group in numbers</p>
        <figure class="legacy-quote">
          <blockquote>
            “The name Mentora is rooted in the word <em>mentor</em> — the
            trusted guide whose value is measured in the quality of counsel
            given over time.”
          </blockquote>
          <figcaption>Mark Butler — Group Managing Partner</figcaption>
        </figure>
      </div>
      <dl class="stats" data-reveal>
        <div class="stat"><dt>HLB Ireland founded</dt><dd data-countup="1976">1976</dd></div>
        <div class="stat"><dt>FutureRange established</dt><dd data-countup="1995">1995</dd></div>
        <div class="stat"><dt>Acquisitions in the past seven years</dt><dd data-countup="12">12</dd></div>
        <div class="stat"><dt>Professionals across the group</dt><dd data-countup="180" data-suffix="+">180+</dd></div>
      </dl>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  /* hero — aurora glow + blueprint grid */
  .hero { overflow: hidden; position: relative; }
  .hero::before {
    content: "";
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(640px 420px at 82% 18%, rgba(234, 182, 51, 0.16), transparent 62%),
      radial-gradient(820px 520px at 8% 92%, rgba(15, 94, 118, 0.35), transparent 62%);
    pointer-events: none;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero::before { animation: aurora 16s ease-in-out infinite alternate; }
  }
  @keyframes aurora {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to { transform: translate3d(-3%, 3%, 0) scale(1.07); }
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(90% 90% at 70% 30%, black, transparent 75%);
    pointer-events: none;
  }
  .hero-grid { position: relative; z-index: 1; }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.26;
    z-index: 0;
    pointer-events: none;
  }
  /* kinetic headline — every word visible, staggered entrance */
  h1 .line { display: block; }
  h1 .w { display: inline-block; }
  @media (prefers-reduced-motion: no-preference) {
    .hero-copy h1 { animation: none; opacity: 1; transform: none; }
    h1 .w {
      opacity: 0;
      transform: translateY(26px);
      animation: rise 0.7s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
      animation-delay: var(--d, 0s);
    }
  }
  /* gold sheen sweep on the static line */
  @media (prefers-reduced-motion: no-preference) {
    .sheen {
      padding-bottom: 0.14em;
      margin-bottom: -0.14em;
      background: linear-gradient(110deg, #f6f5fa 42%, #f2c95e 50%, #f6f5fa 58%);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: sheen 7s ease-in-out infinite;
    }
    .sheen .dot { -webkit-text-fill-color: var(--gold); }
  }
  @keyframes sheen {
    0%, 55% { background-position: 120% 0; }
    85%, 100% { background-position: -60% 0; }
  }
  /* entrance sequence */
  @media (prefers-reduced-motion: no-preference) {
    .hero-copy > *, .hero-media {
      opacity: 0;
      transform: translateY(22px);
      animation: rise 0.75s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }
    .hero-copy > :nth-child(1) { animation-delay: 0.05s; }
    .hero-copy > :nth-child(2) { animation-delay: 0.14s; }
    .hero-copy > :nth-child(3) { animation-delay: 0.24s; }
    .hero-copy > :nth-child(4) { animation-delay: 0.34s; }
    .hero-media { animation-delay: 0.42s; }
  }
  @keyframes rise {
    to { opacity: 1; transform: none; }
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    align-items: center;
    gap: 64px;
    padding-top: 96px;
    padding-bottom: 104px;
  }
  h1 {
    color: #f6f5fa;
    font-size: clamp(2.7rem, 5.6vw, 4.4rem);
    margin-bottom: 28px;
  }
  h1 .dot { color: var(--gold); }
  .lede {
    font-size: 1.15rem;
    max-width: 48ch;
    margin-bottom: 40px;
  }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }

  /* orbit carousel */
  .hero-media { display: grid; justify-items: center; }
  .orbit {
    position: relative;
    width: min(440px, 82vw);
    aspect-ratio: 1;
  }
  .orbit-ring {
    position: absolute;
    inset: -16px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--gold), var(--teal-bright), var(--violet), var(--gold));
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 4px), #000 calc(100% - 3px));
    mask: radial-gradient(farthest-side, transparent calc(100% - 4px), #000 calc(100% - 3px));
    opacity: 0.9;
  }
  @media (prefers-reduced-motion: no-preference) {
    .orbit-ring { animation: spin 18s linear infinite; }
  }
  @keyframes spin {
    to { transform: rotate(1turn); }
  }
  .orbit-mask {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 10, 14, 0.45);
  }
  .orbit-track { display: flex; flex-direction: column; height: 500%; }
  .orbit-track > :global(*) { flex: none; width: 100%; }
  .orbit-track :global(.ph), .orbit-track :global(.slot) { border-radius: 0; border: none; }
  @media (prefers-reduced-motion: no-preference) {
    .orbit-track { animation: carousel 20s cubic-bezier(0.6, 0, 0.2, 1) infinite; }
  }
  @keyframes carousel {
    0%, 20.5% { transform: translateY(0); }
    25%, 45.5% { transform: translateY(-20%); }
    50%, 70.5% { transform: translateY(-40%); }
    75%, 95.5% { transform: translateY(-60%); }
    100% { transform: translateY(-80%); }
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 72px;
    align-items: center;
  }
  .intro h2 { margin-bottom: 26px; }
  .intro .body p { max-width: 62ch; }
  .intro .body p + p { margin-top: 18px; }

  /* firms */
  .firms { padding: 110px 0; }
  .firms-head {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: end;
    margin-bottom: 46px;
  }
  .firms-head h2 { margin-bottom: 0; }
  .firms-copy p { max-width: 52ch; }
  .firms-copy p + p { margin-top: 12px; }
  .firm-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  .firm {
    display: block;
    background: var(--surface);
    border: 1px solid var(--line);
    border-top: 4px solid var(--gold);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .firm :global(.ph), .firm :global(.slot) { border-radius: 0; border-left: none; border-right: none; border-top: none; }
  @media (prefers-reduced-motion: no-preference) {
    .firm:hover {
      transform: translateY(-5px);
      box-shadow: 0 22px 48px rgba(26, 41, 48, 0.16), 0 0 0 1px rgba(234, 182, 51, 0.55);
    }
  }
  .firm-body { display: block; padding: 28px 30px 32px; }
  .firm .tag {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--gold-deep);
    display: block;
    margin-bottom: 10px;
  }
  .firm .name {
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--head);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .firm .go {
    font-size: 1.2rem;
    font-weight: 400;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line);
    display: grid;
    place-items: center;
    border-radius: 999px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    flex: none;
  }
  .firm:hover .go {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--ink);
  }
  /* FutureRange card is teal-coded */
  .firm-teal { border-top-color: var(--teal-bright); }
  .firm-teal .tag { color: var(--teal-ink); }
  @media (prefers-reduced-motion: no-preference) {
    .firm-teal:hover {
      box-shadow: 0 22px 48px rgba(26, 41, 48, 0.16), 0 0 0 1px rgba(59, 191, 208, 0.6);
    }
  }
  .firm-teal:hover .go {
    background: var(--teal-bright);
    border-color: var(--teal-bright);
    color: #06272c;
  }
  .firm .desc {
    display: block;
    color: var(--body);
    font-size: 0.95rem;
    margin-top: 10px;
    max-width: 46ch;
  }

  /* trust bar — slim credential strip, continuous with the firms section */
  .trust { padding: 0 0 100px; }
  .trust-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 24px 40px;
    padding-top: 40px;
    border-top: 1px solid var(--line);
  }
  .cred { display: flex; flex-direction: column; gap: 4px; }
  .cred-main {
    font-weight: 800;
    font-size: 1rem;
    color: var(--head);
    letter-spacing: -0.01em;
  }
  .cred-sub {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--body);
  }

  /* testimonials */
  .voices { padding: 100px 0; background: var(--ink-deep); }
  .voices-head { max-width: 640px; margin-bottom: 56px; }
  .voices-head .section-title { color: #f0f4f5; }
  .voices-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
  }
  .voice {
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--hairline-band);
    border-radius: var(--radius-lg);
    padding: 30px 28px 26px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .voice blockquote {
    margin: 0;
    color: #eef3f4;
    font-size: 1.02rem;
    line-height: 1.55;
    position: relative;
    padding-top: 30px;
  }
  .voice blockquote::before {
    content: "\201C";
    position: absolute;
    top: -6px;
    left: -2px;
    font-family: var(--font-serif);
    font-size: 3.2rem;
    line-height: 1;
    color: var(--gold);
  }
  .voice figcaption { display: flex; flex-direction: column; gap: 3px; margin-top: auto; }
  .voice .who { font-weight: 800; color: #fff; font-size: 0.95rem; }
  .voice .org {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal-bright);
  }

  /* numbers — soft gold glow (lighter slate band) */
  .legacy { padding: 100px 0; position: relative; overflow: hidden; }
  .legacy::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(720px 420px at 88% 80%, rgba(234, 182, 51, 0.1), transparent 65%);
    pointer-events: none;
  }
  .legacy .container { position: relative; }
  .legacy-head { max-width: 760px; margin-bottom: 64px; }
  .legacy-quote blockquote {
    font-family: var(--font-serif);
    font-weight: 460;
    font-size: clamp(1.5rem, 2.9vw, 2.3rem);
    line-height: 1.4;
    color: #f0f4f5;
    letter-spacing: 0;
    max-width: 28ch;
  }
  .legacy-quote em {
    font-style: italic;
    color: var(--gold);
  }
  .legacy-quote figcaption {
    margin-top: 16px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-on-dark);
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 34px;
    border-top: 1px solid var(--hairline-band);
    padding-top: 48px;
  }
  .stat { display: flex; flex-direction: column-reverse; justify-content: flex-end; }
  .stat dd {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.8rem, 4.6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--gold);
    line-height: 1;
  }
  .stat dt {
    margin-top: 12px;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--muted-on-dark);
    max-width: 20ch;
  }

  /* approach */
  .approach { padding: 110px 0; background: var(--band-bg); }
  .approach-head { max-width: 680px; margin-bottom: 56px; }
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .pillar {
    background: var(--surface);
    padding: 44px 38px;
    position: relative;
  }
  .pillar::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 4px;
    background: var(--gold);
  }
  @media (prefers-reduced-motion: no-preference) {
    .pillar::before { transition: width 0.3s ease; }
  }
  .pillar:hover::before { width: 100%; }
  .pillar h3 { font-size: 1.3rem; margin-bottom: 12px; }
  .pillar p { font-size: 0.95rem; }
  .pillar a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pillar a:hover { color: var(--gold-deep); }

