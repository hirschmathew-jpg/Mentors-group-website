---
import { href } from '../lib/paths';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cta from '../components/Cta.astro';
import PostCard from '../components/PostCard.astro';
import Placeholder from '../components/Placeholder.astro';

const posts = (await getCollection('insights'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const services = [
  'Audit & Assurance',
  'Taxation',
  'Business Advisory',
  'Corporate Finance',
  'Cyber Security',
  'Managed IT',
  'Cloud, AI & Transformation',
];
---

<BaseLayout
  title="Mentora Group — Audit. Advisory. Technology. One group."
  description="Mentora Group is the holding company of HLB Ireland, an audit, accounting and tax advisory firm, and FutureRange, an IT services firm — serving ambitious businesses across Ireland."
>
  <!-- Hero -->
  <section class="hero band on-dark">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">The Mentora Group</p>
        <h1>Audit<span class="dot">.</span> Advisory<span class="dot">.</span> Technology<span class="dot">.</span><br />One group<span class="dot">.</span></h1>
        <p class="lede">
          Mentora Group is the holding company of HLB Ireland and FutureRange
          — 180+ professionals across audit, accounting, tax and IT, for
          ambitious businesses across Ireland.
        </p>
        <div class="hero-actions">
          <a class="btn btn-gold" href={href('/contact/')}>Talk to us <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href={href('/about/')}>About the group</a>
        </div>
      </div>
      <div class="hero-media">
        <Placeholder label="Insert image" ratio="4 / 3" dark />
      </div>
    </div>
  </section>

  <!-- Service strip -->
  <div class="strip">
    <div class="container strip-inner" aria-label="Group services">
      {services.map((s, i) => (
        <>
          {i > 0 && <span class="diamond" aria-hidden="true">◆</span>}
          <span>{s}</span>
        </>
      ))}
    </div>
  </div>

  <!-- Intro -->
  <section class="intro">
    <div class="container intro-grid">
      <div data-reveal>
        <p class="eyebrow">Who we are</p>
        <h2 class="section-title title-accent">One group. Two established firms.</h2>
        <div class="body">
          <p>
            Mentora Group is the holding company of HLB Ireland, an audit,
            accounting and tax advisory firm working with ambitious domestic
            and international businesses since 1976, and FutureRange, an IT
            services firm providing cyber security, managed services and
            digital transformation since 1995.
          </p>
          <p>
            Each firm keeps the name, team and relationships its clients know.
            Behind them, the group provides shared strength, stability and
            investment for the long term.
          </p>
        </div>
      </div>
      <div class="intro-media" data-reveal>
        <Placeholder label="Insert image" ratio="4 / 3" />
      </div>
    </div>
  </section>

  <!-- Firms -->
  <section class="firms">
    <div class="container">
      <div class="firms-head" data-reveal>
        <div>
          <p class="eyebrow">Our firms</p>
          <h2 class="section-title">Two specialisms, one owner</h2>
        </div>
        <p>
          Audit, accounting, tax, cyber security, managed IT and digital
          transformation — a comprehensive offering across the group.
        </p>
      </div>
      <div class="firm-cards">
        <a class="firm" href="https://www.hlb.ie" rel="noopener" data-reveal>
          <Placeholder label="Insert image" ratio="16 / 9" />
          <span class="firm-body">
            <span class="tag">Audit, Accounting &amp; Tax</span>
            <span class="name">HLB Ireland <span class="go" aria-hidden="true">→</span></span>
            <span class="desc">Audit &amp; assurance, accounting, taxation and business advisory — since 1976.</span>
          </span>
        </a>
        <a class="firm" href="https://www.futurerange.ie" rel="noopener" data-reveal>
          <Placeholder label="Insert image" ratio="16 / 9" />
          <span class="firm-body">
            <span class="tag">Managed IT, Security &amp; Digital</span>
            <span class="name">FutureRange <span class="go" aria-hidden="true">→</span></span>
            <span class="desc">Cyber security &amp; managed operations, modern workplace, and cloud, AI &amp; transformation — since 1995.</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- The group in numbers -->
  <section class="legacy band on-dark">
    <div class="container">
      <div class="legacy-head" data-reveal>
        <p class="eyebrow">The group in numbers</p>
        <h2 class="section-title">Established expertise, held for the long term</h2>
        <p class="legacy-sub">
          Mentora exists to give both firms a permanent home — with the backing
          to invest, acquire and grow, while every client keeps the team they
          trust.
        </p>
      </div>
      <dl class="stats" data-reveal>
        <div class="stat"><dt>HLB Ireland founded</dt><dd>1976</dd></div>
        <div class="stat"><dt>FutureRange established</dt><dd>1995</dd></div>
        <div class="stat"><dt>Acquisitions in the past seven years</dt><dd>12</dd></div>
        <div class="stat"><dt>Professionals across the group</dt><dd>180+</dd></div>
      </dl>
    </div>
  </section>

  <!-- How we work -->
  <section class="approach">
    <div class="container">
      <div class="approach-head" data-reveal>
        <p class="eyebrow">How we work</p>
        <h2 class="section-title title-accent">What the group gets you in practice</h2>
      </div>
      <div class="pillars" data-reveal>
        <div class="pillar">
          <h3>Finance and IT at one table</h3>
          <p>
            The same group holds your accountants and your IT provider. When a
            question spans both — systems for a new entity, security around
            financial data, technology due diligence on a deal — HLB Ireland
            and FutureRange work it together, and you deal with one group.
          </p>
        </div>
        <div class="pillar">
          <h3>Partner-led, not passed down</h3>
          <p>
            Every HLB Ireland assignment is led by a partner — you deal
            directly with the person responsible for your work, with 180
            professionals behind them when the job needs scale.
          </p>
        </div>
        <div class="pillar">
          <h3>A home for good practices</h3>
          <p>
            Twelve practices have joined the group in seven years, and we
            remain open to more where the fit is right. Planning succession or
            the sale of your practice? {/* JOIN-PAGE: revert href to '/contact/' if the join page is removed */}
            <a href={href('/join-the-group/')}>Talk to us in confidence</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Insights -->
  <section class="insights">
    <div class="container">
      <div class="insights-head" data-reveal>
        <div>
          <p class="eyebrow">Insights</p>
          <h2 class="section-title">Latest from the group</h2>
        </div>
        <a class="all-link" href={href('/insights/')}>All insights</a>
      </div>
      <div class="posts">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  /* hero */
  .hero { overflow: hidden; }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    align-items: center;
    gap: 64px;
    padding-top: 96px;
    padding-bottom: 104px;
  }
  h1 {
    color: #f6f5fa;
    font-size: clamp(2.7rem, 5.6vw, 4.4rem);
    margin-bottom: 28px;
  }
  h1 .dot { color: var(--gold); }
  .lede {
    font-size: 1.15rem;
    max-width: 48ch;
    margin-bottom: 40px;
  }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }

  /* service strip */
  .strip {
    background: var(--ink-deep);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .strip-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 12px 18px;
    padding-top: 18px;
    padding-bottom: 18px;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a3b7bd;
  }
  .diamond { color: var(--gold); font-size: 0.55rem; }

  /* intro */
  .intro { padding: 110px 0 90px; }
  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 72px;
    align-items: center;
  }
  .intro h2 { margin-bottom: 26px; }
  .intro .body p { max-width: 62ch; }
  .intro .body p + p { margin-top: 18px; }

  /* firms */
  .firms { padding: 40px 0 110px; }
  .firms-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 44px;
  }
  .firms-head p { max-width: 42ch; }
  .firm-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  .firm {
    display: block;
    background: #fff;
    border: 1px solid var(--line);
    border-top: 4px solid var(--gold);
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .firm:hover {
      transform: translateY(-4px);
      box-shadow: 0 18px 40px rgba(26, 41, 48, 0.14);
    }
  }
  .firm-body { display: block; padding: 28px 30px 32px; }
  .firm .tag {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--gold-deep);
    display: block;
    margin-bottom: 10px;
  }
  .firm .name {
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--head);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .firm .go {
    font-size: 1.2rem;
    font-weight: 400;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line);
    display: grid;
    place-items: center;
    border-radius: 999px;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    flex: none;
  }
  .firm:hover .go {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--ink);
  }
  .firm .desc {
    display: block;
    color: var(--body);
    font-size: 0.95rem;
    margin-top: 10px;
    max-width: 46ch;
  }

  /* numbers */
  .legacy { padding: 100px 0; }
  .legacy-head { max-width: 680px; margin-bottom: 64px; }
  .legacy-head h2 { margin-bottom: 16px; }
  .legacy-sub { color: var(--muted-on-dark); }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 34px;
    border-top: 1px solid var(--hairline-band);
    padding-top: 48px;
  }
  .stat { display: flex; flex-direction: column-reverse; justify-content: flex-end; }
  .stat dd {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.8rem, 4.6vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--gold);
    line-height: 1;
  }
  .stat dt {
    margin-top: 12px;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--muted-on-dark);
    max-width: 20ch;
  }

  /* approach */
  .approach { padding: 110px 0; }
  .approach-head { max-width: 680px; margin-bottom: 56px; }
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .pillar {
    background: #fff;
    padding: 44px 38px;
    position: relative;
  }
  .pillar::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 4px;
    background: var(--gold);
  }
  @media (prefers-reduced-motion: no-preference) {
    .pillar::before { transition: width 0.3s ease; }
  }
  .pillar:hover::before { width: 100%; }
  .pillar h3 { font-size: 1.3rem; margin-bottom: 12px; }
  .pillar p { font-size: 0.95rem; }
  .pillar a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .pillar a:hover { color: var(--gold-deep); }

  /* insights */
  .insights { padding: 0 0 110px; }
  .insights-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 44px;
  }
  .all-link {
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--head);
    border-bottom: 2px solid var(--gold);
    padding-bottom: 4px;
  }
  .all-link:hover { color: var(--gold-deep); }
  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  @media (max-width: 960px) {
    .hero-grid, .intro-grid, .firm-cards { grid-template-columns: 1fr; }
    .hero-grid { padding-top: 72px; padding-bottom: 80px; }
    .stats { grid-template-columns: 1fr 1fr; }
    .pillars { grid-template-columns: 1fr; }
    .posts { grid-template-columns: 1fr; }
    .firms-head { flex-direction: column; align-items: flex-start; }
    .strip-inner { justify-content: flex-start; }
  }
</style>
