  }
  .latest-viewport::-webkit-scrollbar { display: none; }
  .latest-viewport:focus-visible { outline: 2px solid var(--gold); outline-offset: 4px; }
  .latest-viewport > :global(.acard) {
    flex: 0 0 calc((100% - 56px) / 3);
    scroll-snap-align: start;
  }
  :global(html:not(.js)) .latest-nav { display: none; }

  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; }
    .firms-head { grid-template-columns: 1fr; gap: 18px; }
    .firm-cards { grid-template-columns: 1fr; }
    .hero-grid { padding-top: 72px; padding-bottom: 80px; }
    .stats { grid-template-columns: 1fr 1fr; }
    .pillars { grid-template-columns: 1fr; }
    .latest-viewport > :global(.acard) { flex-basis: 82%; }
    .firms-head { flex-direction: column; align-items: flex-start; }
    .insights-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .all-link { white-space: nowrap; }
    .voice { flex-basis: calc((100% - 20px) / 2); }
    .certs { gap: 20px 28px; }
  }
  @media (max-width: 560px) {
    .voices-head { flex-direction: column; align-items: flex-start; }
    .voice { flex-basis: 86%; }
  }
  /* the arrows are a JS enhancement; the viewport still swipes without them */
  :global(html:not(.js)) .voices-nav { display: none; }
</style>

<script>
  // Revolving testimonials carousel with a seamless loop. The set of cards is
  // cloned once; advancing right scrolls into the clones, and once a full set
  // has passed we silently subtract that width so scrolling keeps going right
  // forever instead of snapping back to the start. Native swipe, prev/next,
  // and a gentle auto-advance that pauses on hover, focus, or off-screen.
  function initVoices() {
    if ((window as any).__voicesCleanup) (window as any).__voicesCleanup();
    const vp = document.querySelector<HTMLElement>('[data-voices-viewport]');
    if (!vp) return;
    const originals = [...vp.querySelectorAll<HTMLElement>('.voice:not([data-clone])')];
    if (!originals.length) return;
    const n = originals.length;

    // Clone the whole set once so there is always content to the right.
    if (!vp.querySelector('[data-clone]')) {
      originals.forEach((card) => {
        const c = card.cloneNode(true) as HTMLElement;
        c.setAttribute('data-clone', 'true');
        c.setAttribute('aria-hidden', 'true');
        vp.appendChild(c);
      });
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nav = document.querySelector('.voices-nav');
    if (nav) nav.removeAttribute('aria-hidden');

    const step = () => {
      const gap = parseFloat(getComputedStyle(vp).columnGap) || 20;
      return originals[0].getBoundingClientRect().width + gap;
    };
    const setWidth = () => n * step();
    // Keep scrollLeft within one set; shifting by a full set is invisible
    // because the clones are identical to the originals.
    const normalize = () => {
      const w = setWidth();
      if (w <= 0) return;
      if (vp.scrollLeft >= w) vp.scrollLeft -= w;
      else if (vp.scrollLeft < 0) vp.scrollLeft += w;
    };
    const go = (dir: number) => {
      const behavior: ScrollBehavior = reduce ? 'auto' : 'smooth';
      if (dir < 0 && vp.scrollLeft < step() - 1) vp.scrollLeft += setWidth(); // wrap-left seam
      vp.scrollBy({ left: dir * step(), behavior });
    };

    document.querySelector('[data-voices-next]')?.addEventListener('click', () => go(1));
    document.querySelector('[data-voices-prev]')?.addEventListener('click', () => go(-1));

    // normalise once the scroll settles (invisible; keeps scrollLeft bounded)
    let settle = 0;
    const onScroll = () => { clearTimeout(settle); settle = window.setTimeout(normalize, 120); };
    vp.addEventListener('scroll', onScroll, { passive: true });

    let paused = false;
    let timer = 0;
    const section = vp.closest('.voices') as HTMLElement;
    const startTick = () => { if (reduce || timer) return; timer = window.setInterval(() => { if (!paused) go(1); }, 5000); };
    const stopTick = () => { if (timer) { clearInterval(timer); timer = 0; } };
    section.addEventListener('pointerenter', () => (paused = true));
    section.addEventListener('pointerleave', () => (paused = false));
    vp.addEventListener('focusin', () => (paused = true));
    vp.addEventListener('focusout', () => (paused = false));
    const io = new IntersectionObserver(
      (es) => es.forEach((e) => (e.isIntersecting ? startTick() : stopTick())),
      { threshold: 0.25 }
    );
    io.observe(section);

    (window as any).__voicesCleanup = () => { stopTick(); io.disconnect(); clearTimeout(settle); };
  }
  document.addEventListener('astro:page-load', initVoices);
</script>

<script>
  import { initCarousel } from '../lib/carousel';
  function initLatest() {
    (window as any).__latestCleanup?.();
    const vp = document.querySelector<HTMLElement>('[data-latest-viewport]');
    if (!vp) return;
    (window as any).__latestCleanup = initCarousel(vp, {
      navSelector: '.latest-nav',
      prevSelector: '[data-latest-prev]',
      nextSelector: '[data-latest-next]',
    });
  }
  document.addEventListener('astro:page-load', initLatest);
</script>
