---
import { href } from '../../lib/paths';
import Placeholder from '../../components/Placeholder.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date } = post.data;
const formatted = date.toLocaleDateString('en-IE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Related: the three most recent other articles.
const related = (await getCollection('insights'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Article schema for richer search results.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString().slice(0, 10),
  image: new URL(href(`/og.png`), Astro.site).href,
  author: { '@type': 'Organization', name: 'HLB Ireland', url: 'https://www.hlb.ie' },
  publisher: { '@type': 'Organization', name: 'Mentora Group' },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout title={`${title} — Mentora Group`} description={description} type="article" jsonld={articleSchema}>
  <article>
    <header class="page-hero on-dark">
      <div class="container">
        <p class="crumbs">
          <a href={href('/insights/')}>← Insights</a>
        </p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <p class="date"><time datetime={date.toISOString().slice(0, 10)}>{formatted}</time></p>
      </div>
    </header>

    <div class="container article-body">
      <figure class="feature" data-reveal>
        <Placeholder name={`insight-${post.id}`} label="Insert image" ratio="16 / 8" />
      </figure>
      <div class="prose">
        <Content />
      </div>
    </div>

    {related.length > 0 && (
      <aside class="related">
        <div class="container">
          <h2 class="section-title">More from the group</h2>
          <div class="related-grid">
            {related.map((p) => <PostCard post={p} />)}
          </div>
        </div>
      </aside>
    )}
  </article>

  <Cta title="Talk to us about what this means for your business" />
</BaseLayout>

<style>
  .crumbs {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
    font-size: 0.85rem;
  }
  .crumbs a { color: var(--text-on-dark); }
  .crumbs a:hover { color: var(--gold); }
  .date { margin-top: 16px; font-size: 0.88rem; color: var(--muted-on-dark); }

  .page-hero .container,
  .article-body { max-width: 880px; }
  .article-body { padding: 70px 28px 100px; }
  .feature { margin-bottom: 48px; }

  .related { background: var(--band-bg); padding: 90px 0 100px; }
  .related h2 { margin-bottom: 40px; }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 960px) {
    .related-grid {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 82%;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 12px;
      -webkit-overflow-scrolling: touch;
    }
    .related-grid > :global(*) { scroll-snap-align: start; }
  }
</style>
