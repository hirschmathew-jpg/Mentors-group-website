---
import { href } from '../../lib/paths';
import Placeholder from '../../components/Placeholder.astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, category, date } = post.data;
const formatted = date.toLocaleDateString('en-IE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={`${title} — Mentora Group`} description={description} type="article">
  <article>
    <header class="page-hero on-dark">
      <div class="container">
        <p class="crumbs">
          <a href={href('/insights/')}>← Insights</a>
          <span class="sep" aria-hidden="true">|</span>
          <span class="cat">{category}</span>
        </p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <p class="date"><time datetime={date.toISOString().slice(0, 10)}>{formatted}</time></p>
      </div>
    </header>

    <div class="container article-body">
      <figure class="feature" data-reveal>
        <Placeholder name={`insight-${post.id}`} label="Insert image" ratio="16 / 8" />
      </figure>
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>

  <Cta title="Talk to us about what this means for your business" />
</BaseLayout>

<style>
  .crumbs {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
    font-size: 0.85rem;
  }
  .crumbs a { color: var(--text-on-dark); }
  .crumbs a:hover { color: var(--gold); }
  .sep { color: var(--hairline-band); }
  .cat {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    font-size: 0.72rem;
    color: var(--gold);
  }
  .date { margin-top: 16px; font-size: 0.88rem; color: var(--muted-on-dark); }

  .page-hero .container,
  .article-body { max-width: 880px; }
  .article-body { padding: 70px 28px 100px; }
  .feature { margin-bottom: 48px; }
</style>
