---
import { href } from '../../lib/paths';
import Placeholder from '../../components/Placeholder.astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import articles from '../../data/articles.json';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date } = post.data;
const formatted = date.toLocaleDateString('en-IE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// "More from the group" — a carousel of everything else worth reading: the
// other on-site insights (which open in place) plus the most-recent articles
// from HLB Ireland and FutureRange (which open on their own sites). Newest
// first, so the mix stays current.
const firmOf = (id: string) => (/futurerange|future-range/i.test(id) ? 'FutureRange' : 'HLB Ireland');
const internal = (await getCollection('insights'))
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    date: p.data.date.toISOString().slice(0, 10),
    firm: firmOf(p.id),
    url: href(`/insights/${p.id}/`),
    internal: true,
  }));
const external = articles.map((a) => ({
  title: a.title,
  description: a.description,
  date: a.date,
  firm: a.firm,
  url: a.url,
  internal: false,
}));
const related = [...internal, ...external].sort(
  (a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-IE', { day: 'numeric', month: 'short', year: 'numeric' });

// Article schema for richer search results.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString().slice(0, 10),
  image: new URL(href(`/og.png`), Astro.site).href,
  author: { '@type': 'Organization', name: 'HLB Ireland', url: 'https://www.hlb.ie' },
  publisher: { '@type': 'Organization', name: 'Mentora Group' },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout title={`${title} — Mentora Group`} description={description} type="article" jsonld={articleSchema}>
  <article>
    <header class="page-hero on-dark">
      <div class="container">
        <p class="crumbs">
          <a href={href('/insights/')}>← Insights</a>
        </p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <p class="date"><time datetime={date.toISOString().slice(0, 10)}>{formatted}</time></p>
      </div>
    </header>

    <div class="container article-body">
      <figure class="feature" data-reveal>
        <Placeholder name={`insight-${post.id}`} label="Insert image" ratio="16 / 8" />
      </figure>
      <div class="prose">
        <Content />
      </div>
    </div>

    {related.length > 0 && (
      <aside class="related">
        <div class="container">
          <div class="related-head" data-reveal>
            <h2 class="section-title">More from the group</h2>
            <div class="rel-nav" aria-hidden="true">
              <button type="button" class="rel-btn" data-rel-prev aria-label="Previous articles">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
              </button>
              <button type="button" class="rel-btn" data-rel-next aria-label="Next articles">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
              </button>
            </div>
          </div>
          <div class="rel-viewport" data-rel-viewport data-reveal tabindex="0" role="group" aria-label="More articles, scrollable">
            {related.map((r) => (
              <a
                class:list={['rel-card', { fr: r.firm === 'FutureRange' }]}
                href={r.url}
                {...(r.internal ? {} : { target: '_blank', rel: 'noopener noreferrer' })}
              >
                <span class="rel-meta">
                  <span class="rel-firm">{r.firm}</span>
                  <time datetime={r.date}>{fmt(r.date)}</time>
                </span>
                <span class="rel-title">
                  {r.title}
                  <span class="rel-ic" aria-hidden="true">{r.internal ? '→' : '↗'}</span>
                </span>
                <span class="rel-desc">{r.description}</span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    )}
  </article>

  <Cta tone="dark" title="Talk to us about what this means for your business" />
</BaseLayout>

<style>
  .crumbs {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
    font-size: 0.85rem;
  }
  .crumbs a { color: var(--text-on-dark); }
  .crumbs a:hover { color: var(--gold); }
  .date { margin-top: 16px; font-size: 0.88rem; color: var(--muted-on-dark); }

  .page-hero .container,
  .article-body { max-width: 880px; }
  .article-body { padding: 70px 28px 100px; }
  .feature { margin-bottom: 48px; }

  /* More from the group — revolving carousel */
  .related { background: var(--band-bg); padding: 90px 0 100px; }
  .related-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 40px;
  }
  .rel-nav { display: flex; gap: 10px; }
  .rel-btn {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--head);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .rel-btn svg { width: 20px; height: 20px; }
  .rel-btn:hover { border-color: var(--gold); color: var(--gold); }
  .rel-btn:active { transform: scale(0.94); }
  .rel-btn:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .rel-viewport {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
  }
  .rel-viewport::-webkit-scrollbar { display: none; }
  .rel-viewport:focus-visible { outline: 2px solid var(--gold); outline-offset: 4px; }

  .rel-card {
    margin: 0;
    flex: 0 0 calc((100% - 40px) / 3);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius-lg);
    padding: 24px 26px 26px;
    color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .rel-card.fr { border-left-color: var(--teal-bright); }
  @media (prefers-reduced-motion: no-preference) {
    .rel-card:hover { transform: translateY(-4px); box-shadow: 0 18px 40px rgba(0, 10, 14, 0.28); }
  }
  .rel-card:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  .rel-meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .rel-firm { font-weight: 800; color: var(--gold-deep); }
  .rel-card.fr .rel-firm { color: var(--teal-ink); }
  .rel-meta time { color: var(--body); }
  .rel-title {
    display: block;
    font-weight: 700;
    font-size: 1.12rem;
    color: var(--head);
    line-height: 1.3;
  }
  .rel-ic { color: var(--gold-deep); font-weight: 800; }
  .rel-card.fr .rel-ic { color: var(--teal-ink); }
  .rel-desc {
    display: block;
    margin-top: 10px;
    font-size: 0.9rem;
    color: var(--body);
    line-height: 1.5;
  }

  /* Without JS the arrows can't run, so the viewport just scrolls natively. */
  :global(html:not(.js)) .rel-nav { display: none; }

  @media (max-width: 960px) {
    .related-head { flex-direction: column; align-items: flex-start; }
    .rel-card { flex-basis: 82%; }
  }
</style>

<script>
  // Revolving "More from the group" carousel with a seamless loop — same
  // mechanism as the testimonials: the card set is cloned once so there is
  // always content to the right, and scrollLeft is normalised by one set width
  // after each move so clicking next keeps going forward forever (and prev
  // wraps back) instead of hitting a hard end. Manual only: prev/next + swipe.
  function initRelated() {
    if ((window as any).__relCleanup) (window as any).__relCleanup();
    const vp = document.querySelector<HTMLElement>('[data-rel-viewport]');
    if (!vp) return;
    const originals = [...vp.querySelectorAll<HTMLElement>('.rel-card:not([data-clone])')];
    if (originals.length < 2) return; // nothing to revolve through
    const n = originals.length;

    if (!vp.querySelector('[data-clone]')) {
      originals.forEach((card) => {
        const c = card.cloneNode(true) as HTMLElement;
        c.setAttribute('data-clone', 'true');
        c.setAttribute('aria-hidden', 'true');
        c.setAttribute('tabindex', '-1');
        vp.appendChild(c);
      });
    }

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const nav = document.querySelector('.rel-nav');
    if (nav) nav.removeAttribute('aria-hidden');

    const step = () => {
      const gap = parseFloat(getComputedStyle(vp).columnGap) || 20;
      return originals[0].getBoundingClientRect().width + gap;
    };
    const setWidth = () => n * step();
    const normalize = () => {
      const w = setWidth();
      if (w <= 0) return;
      if (vp.scrollLeft >= w) vp.scrollLeft -= w;
      else if (vp.scrollLeft < 0) vp.scrollLeft += w;
    };
    const go = (dir: number) => {
      const behavior: ScrollBehavior = reduce ? 'auto' : 'smooth';
      if (dir < 0 && vp.scrollLeft < step() - 1) vp.scrollLeft += setWidth(); // wrap-left seam
      vp.scrollBy({ left: dir * step(), behavior });
    };

    document.querySelector('[data-rel-next]')?.addEventListener('click', () => go(1));
    document.querySelector('[data-rel-prev]')?.addEventListener('click', () => go(-1));

    let settle = 0;
    const onScroll = () => { clearTimeout(settle); settle = window.setTimeout(normalize, 120); };
    vp.addEventListener('scroll', onScroll, { passive: true });

    (window as any).__relCleanup = () => { clearTimeout(settle); };
  }
  document.addEventListener('astro:page-load', initRelated);
</script>
