---
import { href } from '../../lib/paths';
import Placeholder from '../../components/Placeholder.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date } = post.data;
const formatted = date.toLocaleDateString('en-IE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// "More from the group" — a carousel of everything else worth reading: the
// other on-site insights (which open in place) plus the most-recent articles
// from HLB Ireland and FutureRange (which open on their own sites). Newest
// first, so the mix stays current.
const firmOf = (id: string) => (/futurerange|future-range/i.test(id) ? 'FutureRange' : 'HLB Ireland');
const related = (await getCollection('insights'))
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    date: p.data.date.toISOString().slice(0, 10),
    firm: firmOf(p.id) as 'HLB Ireland' | 'FutureRange',
    url: href(`/insights/${p.id}/`),
    internal: true,
    image: `insight-${p.id}`,
  }))
  .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

// Article schema for richer search results.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString().slice(0, 10),
  image: new URL(href(`/og.png`), Astro.site).href,
  author: { '@type': 'Organization', name: 'HLB Ireland', url: 'https://www.hlb.ie' },
  publisher: { '@type': 'Organization', name: 'Mentora Group' },
  mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
};
---

<BaseLayout title={`${title} — Mentora Group`} description={description} type="article" jsonld={articleSchema}>
  <article>
    <header class="page-hero on-dark">
      <div class="container">
        <p class="crumbs">
          <a href={href('/insights/')}>← Insights</a>
        </p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>
        <p class="date"><time datetime={date.toISOString().slice(0, 10)}>{formatted}</time></p>
      </div>
    </header>

    <div class="container article-body">
      <figure class="feature" data-reveal>
        <Placeholder name={`insight-${post.id}`} label="Insert image" ratio="16 / 8" />
      </figure>
      <div class="prose">
        <Content />
      </div>
    </div>

    {related.length > 0 && (
      <aside class="related">
        <div class="container">
          <div class="related-head" data-reveal>
            <h2 class="section-title">More from the group</h2>
            <div class="rel-nav" aria-hidden="true">
              <button type="button" class="rel-btn" data-rel-prev aria-label="Previous articles">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
              </button>
              <button type="button" class="rel-btn" data-rel-next aria-label="Next articles">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
              </button>
            </div>
          </div>
          <div class="rel-viewport" data-rel-viewport data-reveal tabindex="0" role="group" aria-label="More articles, scrollable">
            {related.map((r) => (
              <ArticleCard
                title={r.title}
                description={r.description}
                date={r.date}
                firm={r.firm}
                url={r.url}
                internal={r.internal}
                image={r.image}
              />
            ))}
          </div>
        </div>
      </aside>
    )}
  </article>

  <Cta tone="dark" title="Talk to us about what this means for your business" />
</BaseLayout>

<style>
  .crumbs {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
    font-size: 0.85rem;
  }
  .crumbs a { color: var(--text-on-dark); }
  .crumbs a:hover { color: var(--gold); }
  .date { margin-top: 16px; font-size: 0.88rem; color: var(--muted-on-dark); }

  .page-hero .container,
  .article-body { max-width: 880px; }
  .article-body { padding: 70px 28px 100px; }
  .feature { margin-bottom: 48px; }

  /* More from the group — revolving carousel */
  .related { background: var(--band-bg); padding: 90px 0 100px; }
  .related-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 40px;
  }
  .rel-nav { display: flex; gap: 10px; }
  .rel-btn {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--head);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .rel-btn svg { width: 20px; height: 20px; }
  .rel-btn:hover { border-color: var(--gold); color: var(--gold); }
  .rel-btn:active { transform: scale(0.94); }
  .rel-btn:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

  .rel-viewport {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
  }
  .rel-viewport::-webkit-scrollbar { display: none; }
  .rel-viewport:focus-visible { outline: 2px solid var(--gold); outline-offset: 4px; }

  .rel-viewport > :global(.acard) {
    flex: 0 0 calc((100% - 40px) / 3);
    scroll-snap-align: start;
  }

  /* Without JS the arrows can't run, so the viewport just scrolls natively. */
  :global(html:not(.js)) .rel-nav { display: none; }

  @media (max-width: 960px) {
    .related-head { flex-direction: column; align-items: flex-start; }
    .rel-viewport > :global(.acard) { flex-basis: 82%; }
  }
</style>

<script>
  import { initCarousel } from '../../lib/carousel';
  function initRelated() {
    (window as any).__relCleanup?.();
    const vp = document.querySelector<HTMLElement>('[data-rel-viewport]');
    if (!vp) return;
    (window as any).__relCleanup = initCarousel(vp, {
      navSelector: '.rel-nav',
      prevSelector: '[data-rel-prev]',
      nextSelector: '[data-rel-next]',
    });
  }
  document.addEventListener('astro:page-load', initRelated);
</script>
