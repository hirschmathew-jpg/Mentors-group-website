---
import { href } from '../../lib/paths';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import PostCard from '../../components/PostCard.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import ServicesStrip from '../../components/ServicesStrip.astro';

const firmOf = (id: string) => (/futurerange|future-range/i.test(id) ? 'FutureRange' : 'HLB Ireland');
const all = (await getCollection('insights')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
// The three most recent lead as full feature cards; the rest fill the archive.
const featured = all.slice(0, 3);
const archive = all.slice(3).map((p) => ({
  title: p.data.title,
  description: p.data.description,
  date: p.data.date.toISOString().slice(0, 10),
  firm: firmOf(p.id) as 'HLB Ireland' | 'FutureRange',
  url: href(`/insights/${p.id}/`),
  image: `insight-${p.id}`,
}));
---

<BaseLayout
  title="Insights — Mentora Group"
  description="Insights, commentary and updates from across the Mentora Group — practical guidance on advisory, technology and cybersecurity for Irish businesses."
>
  <section class="page-hero on-dark">
    <div class="container">
      <p class="eyebrow">Insights</p>
      <h1>Commentary and updates from across the group</h1>
      <p class="lede">
        Thought leadership, practical guidance and expert perspectives — what's
        happening, what it means for your business, and what to do next.
      </p>
    </div>
  </section>

  <!-- Service strip (marquee) -->
  <ServicesStrip />

  <section class="listing" aria-label="Articles">
    <div class="container">
      <h2 class="visually-hidden">Featured articles</h2>
      <div class="posts">
        {featured.map((post) => <PostCard post={post} />)}
      </div>

      <div class="archive" data-archive hidden>
        <h2 class="arc-head">More from HLB Ireland &amp; FutureRange</h2>
        <div class="arc-grid">
          {archive.map((a) => (
            <ArticleCard
              title={a.title}
              description={a.description}
              date={a.date}
              firm={a.firm}
              url={a.url}
              internal={true}
              image={a.image}
            />
          ))}
        </div>
      </div>

      <div class="more-wrap">
        <button class="btn btn-more" type="button" data-show-more aria-expanded="false">
          Show more articles
        </button>
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .listing { padding: 90px 0 110px; }
  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .archive { margin-top: 64px; }
  .arc-head {
    font-size: 1.1rem;
    color: var(--head);
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }
  .arc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .more-wrap { display: flex; justify-content: center; margin-top: 44px; }
  .btn-more {
    background: transparent;
    color: var(--head);
    border: 1px solid var(--line);
    cursor: pointer;
  }
  .btn-more:hover { border-color: var(--gold); color: var(--gold); }
  /* Without JS the arrows/toggle can't run, so just show everything. */
  :global(html:not(.js)) .archive { display: block !important; }
  :global(html:not(.js)) .more-wrap { display: none; }

  @media (max-width: 960px) {
    .posts { grid-template-columns: 1fr; }
    .arc-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 961px) and (max-width: 1180px) {
    .arc-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  // Reveal the archive six articles at a time; once everything is shown the
  // button collapses it again.
  const STEP = 6;
  document.addEventListener('astro:page-load', () => {
    const btn = document.querySelector<HTMLButtonElement>('[data-show-more]');
    const archive = document.querySelector<HTMLElement>('[data-archive]');
    if (!btn || !archive || (archive as any).__moreBound) return;
    (archive as any).__moreBound = true;

    const cards = [...archive.querySelectorAll<HTMLElement>('.arc-grid > .acard')];
    let shown = 0;
    const render = () => {
      // inline display beats the card's own `display:flex`, which would
      // otherwise override the [hidden] attribute.
      cards.forEach((c, i) => (c.style.display = i < shown ? '' : 'none'));
      archive.toggleAttribute('hidden', shown === 0);
      btn.textContent = shown >= cards.length ? 'Show fewer articles' : 'Show more articles';
      btn.setAttribute('aria-expanded', shown > 0 ? 'true' : 'false');
    };
    render();

    btn.addEventListener('click', () => {
      if (shown >= cards.length) {
        shown = 0;
        render();
        archive.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        shown = Math.min(shown + STEP, cards.length);
        render();
      }
    });
  });
</script>
