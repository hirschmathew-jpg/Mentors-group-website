---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import PostCard from '../../components/PostCard.astro';
import ServicesStrip from '../../components/ServicesStrip.astro';

const posts = (await getCollection('insights')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Insights — Mentora Group"
  description="Insights, commentary and updates from across the Mentora Group — practical guidance on advisory, technology and cybersecurity for Irish businesses."
>
  <section class="page-hero on-dark">
    <div class="container">
      <p class="eyebrow">Insights</p>
      <h1>Commentary and updates from across the group</h1>
      <p class="lede">
        Thought leadership, practical guidance and expert perspectives — what's
        happening, what it means for your business, and what to do next.
      </p>
    </div>
  </section>

  <!-- Service strip (marquee) -->
  <ServicesStrip />

  <section class="listing">
    <div class="container">
      <div class="posts">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .listing { padding: 90px 0 110px; }
  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  @media (max-width: 960px) {
    .posts { grid-template-columns: 1fr; }
  }
</style>
