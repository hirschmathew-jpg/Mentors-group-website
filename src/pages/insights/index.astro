---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cta from '../../components/Cta.astro';
import PostCard from '../../components/PostCard.astro';
import ServicesStrip from '../../components/ServicesStrip.astro';
import articles from '../../data/articles.json';

const posts = (await getCollection('insights')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-IE', { day: 'numeric', month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Insights — Mentora Group"
  description="Insights, commentary and updates from across the Mentora Group — practical guidance on advisory, technology and cybersecurity for Irish businesses."
>
  <section class="page-hero on-dark">
    <div class="container">
      <p class="eyebrow">Insights</p>
      <h1>Commentary and updates from across the group</h1>
      <p class="lede">
        Thought leadership, practical guidance and expert perspectives — what's
        happening, what it means for your business, and what to do next.
      </p>
    </div>
  </section>

  <!-- Service strip (marquee) -->
  <ServicesStrip />

  <section class="listing" aria-label="Articles">
    <div class="container">
      <h2 class="visually-hidden">Featured articles</h2>
      <div class="posts">
        {posts.map((post) => <PostCard post={post} />)}
      </div>

      <div class="archive" data-archive hidden>
        <h2 class="arc-head">More from HLB Ireland &amp; FutureRange</h2>
        <div class="arc-grid">
          {articles.map((a) => (
            <a
              class:list={['arc', { fr: a.firm === 'FutureRange' }]}
              href={a.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="arc-meta">
                <span class="arc-firm">{a.firm}</span>
                <time datetime={a.date}>{fmt(a.date)}</time>
              </span>
              <span class="arc-title">{a.title} <span class="arc-ext" aria-hidden="true">↗</span></span>
              <span class="arc-desc">{a.description}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="more-wrap">
        <button class="btn btn-more" type="button" data-show-more aria-expanded="false">
          Show more articles
        </button>
      </div>
    </div>
  </section>

  <Cta />
</BaseLayout>

<style>
  .listing { padding: 90px 0 110px; }
  .posts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .archive { margin-top: 64px; }
  .arc-head {
    font-size: 1.1rem;
    color: var(--head);
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }
  .arc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .arc {
    display: block;
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    border-radius: var(--radius-sm);
    padding: 20px 22px;
    color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .arc.fr { border-left-color: var(--teal-bright); }
  @media (prefers-reduced-motion: no-preference) {
    .arc:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(0, 10, 14, 0.28); }
  }
  .arc:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  .arc-meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .arc-firm { font-weight: 800; color: var(--gold-deep); }
  .arc.fr .arc-firm { color: var(--teal-ink); }
  .arc-meta time { color: var(--body); }
  .arc-title { display: block; font-weight: 700; color: var(--head); line-height: 1.3; }
  .arc-ext { color: var(--gold-deep); font-weight: 800; }
  .arc.fr .arc-ext { color: var(--teal-ink); }
  .arc-desc {
    display: block;
    margin-top: 8px;
    font-size: 0.88rem;
    color: var(--body);
    line-height: 1.5;
  }

  .more-wrap { display: flex; justify-content: center; margin-top: 44px; }
  .btn-more {
    background: transparent;
    color: var(--head);
    border: 1px solid var(--line);
    cursor: pointer;
  }
  .btn-more:hover { border-color: var(--gold); color: var(--gold); }
  /* Without JS the arrows/toggle can't run, so just show everything. */
  :global(html:not(.js)) .archive { display: block !important; }
  :global(html:not(.js)) .more-wrap { display: none; }

  @media (max-width: 960px) {
    .posts { grid-template-columns: 1fr; }
    .arc-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.querySelector<HTMLButtonElement>('[data-show-more]');
    const archive = document.querySelector<HTMLElement>('[data-archive]');
    if (!btn || !archive) return;
    btn.addEventListener('click', () => {
      const open = archive.hasAttribute('hidden');
      if (open) {
        archive.removeAttribute('hidden');
        btn.textContent = 'Show fewer articles';
        btn.setAttribute('aria-expanded', 'true');
      } else {
        archive.setAttribute('hidden', '');
        btn.textContent = 'Show more articles';
        btn.setAttribute('aria-expanded', 'false');
        archive.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  });
</script>
