---
// JOIN-PAGE: this page is self-contained. To remove it entirely, delete this
// file and revert the two links marked "JOIN-PAGE" in src/pages/index.astro
// and src/pages/contact.astro.
import { href } from '../lib/paths';
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { n: '12', l: 'Practices joined in seven years' },
  { n: '180+', l: 'Professionals across the group' },
  { n: '2025', l: 'Cardinal Capital investment' },
];
---

<BaseLayout
  title="Join the group — Mentora Group"
  description="Planning succession or the sale of your practice? Mentora Group offers a permanent home for good practices — 12 have joined in seven years. Talk to us in confidence."
>
  <section class="page-hero on-dark">
    <div class="container">
      <p class="eyebrow">Join the group</p>
      <h1>A permanent home for good practices</h1>
      <p class="lede">
        Twelve practices have joined the group in the past seven years —
        accounting firms into HLB Ireland, technology firms into FutureRange.
        If you are planning succession or the sale of your practice, this page
        is for you.
      </p>
    </div>
  </section>

  <section class="pitch">
    <div class="container pitch-grid">
      <div data-reveal>
        <p class="eyebrow">What stays the same</p>
        <h2 class="section-title">Your clients keep the team they trust</h2>
        <p>
          Joining the group does not mean disappearing into it. Client
          relationships stay with the people who built them, work remains
          partner-led, and where a name carries weight it can keep operating
          under it — FutureRange has run under its own brand since joining.
        </p>
        <blockquote>
          “People are central to all of our integrations.”
          <footer>— Mark Butler, Managing Partner, HLB Ireland</footer>
        </blockquote>
      </div>
      <div data-reveal>
        <p class="eyebrow">What you gain</p>
        <h2 class="section-title">Scale your clients can feel</h2>
        <p>
          Practices that join bring their clients access to the group's wider
          service lines — M&amp;A advisory, tax planning, succession planning,
          audit, outsourcing, and the technology and cybersecurity capability
          of FutureRange — with 180 professionals behind every engagement and
          the backing of Cardinal Capital's 2025 investment.
        </p>
        <p>
          We look for a strong cultural and professional fit and a shared
          commitment to high-quality client service — not scale for its own
          sake.
        </p>
      </div>
    </div>
  </section>

  <section class="band on-dark record">
    <div class="container">
      <div data-reveal>
        <p class="eyebrow">Track record</p>
        <h2 class="section-title">Firms that have made the move</h2>
        <p class="record-sub">
          From Conlan Crotty Murray — the first major merger in 2019 — to
          Leahy O'Riordan in April 2026, with Garry IT, DigitalWell, Echo IT
          and EOS Systems joining on the technology side.
        </p>
      </div>
      <dl class="stats" data-reveal>
        {stats.map((s) => (
          <div class="stat"><dt>{s.l}</dt><dd>{s.n}</dd></div>
        ))}
      </dl>
    </div>
  </section>

  <section class="confidential">
    <div class="container conf-grid">
      <div data-reveal>
        <p class="eyebrow">In confidence</p>
        <h2 class="section-title">A conversation costs nothing</h2>
        <p>
          Every discussion is confidential and without obligation. Tell us a
          little about your practice and the timeline you have in mind, and
          the right person will come back to you directly.
        </p>
      </div>
      <div class="actions" data-reveal>
        <a class="btn btn-gold" href={href('/contact/')}>Start the conversation <span aria-hidden="true">→</span></a>
        <a class="btn btn-outline" href="mailto:info@hlb.ie">info@hlb.ie</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pitch { padding: 100px 0 90px; }
  .pitch-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .pitch h2 { margin-bottom: 18px; }
  .pitch p { max-width: 52ch; }
  .pitch p + p { margin-top: 16px; }
  blockquote {
    margin-top: 26px;
    border-left: 3px solid var(--gold);
    padding-left: 18px;
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--head);
    line-height: 1.5;
  }
  blockquote footer {
    margin-top: 8px;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--body);
  }

  .record { padding: 90px 0; }
  .record h2 { margin-bottom: 14px; }
  .record-sub { color: var(--muted-on-dark); max-width: 60ch; }
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 34px;
    border-top: 1px solid var(--hairline-band);
    padding-top: 44px;
    margin-top: 48px;
  }
  .stat { display: flex; flex-direction: column-reverse; justify-content: flex-end; }
  .stat dd {
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.2rem, 3.6vw, 3rem);
    font-weight: 500;
    color: var(--gold);
    line-height: 1;
  }
  .stat dt {
    margin-top: 10px;
    font-size: 0.85rem;
    color: var(--muted-on-dark);
    max-width: 22ch;
  }

  .confidential { padding: 100px 0 110px; }
  .conf-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
  }
  .confidential h2 { margin-bottom: 14px; }
  .confidential p { max-width: 50ch; }
  .actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-self: end;
  }
  .btn-outline {
    border: 1px solid var(--head);
    color: var(--head);
    background: transparent;
    text-transform: none;
    letter-spacing: 0.02em;
  }
  .btn-outline:hover { border-color: var(--gold-deep); color: var(--gold-deep); }

  @media (max-width: 900px) {
    .pitch-grid, .conf-grid { grid-template-columns: 1fr; }
    .stats { grid-template-columns: 1fr; gap: 24px; }
    .actions { justify-self: start; }
  }
</style>
