---
import BaseLayout from '../layouts/BaseLayout.astro';
// NOTE: baseline terms text — have it reviewed by the group's legal adviser
// before launch.
---

<BaseLayout
  title="Terms of Use — Mentora Group"
  description="Terms of use for the Mentora Group website."
>
  <section class="page-hero on-dark">
    <div class="container">
      <p class="eyebrow">Legal</p>
      <h1>Terms of Use</h1>
      <p class="lede">Last updated: July 2026</p>
      </div>
    </div>
  </section>

  <section class="legal">
    <div class="container">
      <div class="prose">
      <p>
        This website is operated by Mentora Group. By using it, you accept
        these terms of use.
      </p>

      <h2>Information, not advice</h2>
      <p>
        The content on this website is provided for general information only.
        It does not constitute professional advice — accounting, tax, legal,
        technological or otherwise — and should not be relied upon as such.
        Please speak to us directly before acting on anything you read here.
      </p>

      <h2>Intellectual property</h2>
      <p>
        The Mentora Group name, logo and all content on this website are the
        property of Mentora Group or its licensors and may not be reproduced
        without permission.
      </p>

      <h2>External links</h2>
      <p>
        Links to other websites — including those of HLB Ireland, FutureRange
        and third parties — are provided for convenience. We are not
        responsible for the content of external sites.
      </p>

      <h2>Liability</h2>
      <p>
        While we take care to keep the information on this site accurate and
        up to date, we make no warranties as to its completeness or accuracy
        and accept no liability for loss arising from reliance on it, to the
        fullest extent permitted by law.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about these terms? Contact us at
        <a href="mailto:info@hlb.ie">info@hlb.ie</a>.
      </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { padding: 80px 0 110px; }
</style>
